<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://qconsulting.ca/fo3/ModConfig5.0.xsd">
	<moduleName>AmmoCheck by Priler</moduleName>
	<requiredInstallFiles>
		<folder source="gamedata" destination="gamedata" />
	</requiredInstallFiles>
	<installSteps order="Explicit">
		<installStep name="Dependency Scripts">
			<optionalFileGroups order="Explicit">
				<group name="-" type="SelectAny">
					<plugins order="Explicit">
						<plugin name="Common animation scripts">
							<description>Usually you don't need to install those scripts since they come included with a lot of weapon mods by default. Also don't install them if you are running G.A.M.M.A., it already has them.</description>
							<files>
								<folder source="dependencies\gamedata" destination="gamedata" priority="0" />
							</files>
							<typeDescriptor>
								<type name="Optional" />
							</typeDescriptor>
						</plugin>
					</plugins>
				</group>
			</optionalFileGroups>
		</installStep>
	</installSteps>
</config>

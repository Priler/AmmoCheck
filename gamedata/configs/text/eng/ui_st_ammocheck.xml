    <string id="ui_mcm_rax_ammo_check_render_cursor_gap">
        <text>Cursor Distance</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_render_cursor_gap_desc">
        <text>Distance (pixels) from the crosshair to the message, for the "Near Cursor" render positions. No effect on the other positions.</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_show_ammo_type">
        <text>Show Ammo Type</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_show_ammo_type_desc">
        <text>Display the ammo type name in the message (e.g. "9x19 BP", "5.45x39 PS").</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_show_ammo_tag">
        <text>Show Ammo Tag</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_show_ammo_tag_desc">
        <text>Append ammo classification tag to the message (e.g. (AP), (HP), (FMJ), (SL), (BK)).</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_highlight_ammo_mode">
        <text>Ammo Type Highlight</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_highlight_ammo_mode_desc">
        <text>Color the message based on ammo type. None: use ammo level color. Whole message: color entire line by ammo type. Separate lines: show ammo tag on second line with its color. Combined: keep the ammo-level color on the main text/bar AND color the ammo type/tag (inline with Custom Text Render; on a second line otherwise).</text>
    </string>

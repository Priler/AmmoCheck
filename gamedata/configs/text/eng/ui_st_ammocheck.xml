    <!-- Display Settings -->
    <string id="ui_mcm_rax_ammo_check_show_message">
        <text>Show Ammo Message</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_show_message_desc">
        <text>Display the ammo status text after checking. Turn OFF to play only the animation with no on-screen message.</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_hide_msg_on_inspect">
        <text>Hide Message Only on Inspect Animation</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_hide_msg_on_inspect_desc">
        <text>When ON, the ammo message is hidden ONLY for weapons that play a proper inspect animation (anm_ammo_check). Weapons that fall back to fake reload, bolt cycle, lower weapon, or hide/show still display the message. Requires "Show Ammo Message" to be ON.</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_usecolor">
        <text>Colored Messages</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_usecolor_desc">
        <text>Enable color-coded messages based on ammo level (red = low, white = full).</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_color_intensity">
        <text>Color Intensity</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_color_intensity_desc">
        <text>Adjust the brightness of colored messages. Lower values produce dimmer colors.</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_display_mode">
        <text>Display Mode</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_display_mode_desc">
        <text>Choose how ammo count is displayed: text description, numeric count, or both.</text>
    </string>
    <!-- Display Mode List Options (no ui_mcm_ prefix for list values) -->
    <string id="rax_ammo_check_display_mode_lst_dm_text">
        <text>Text Only</text>
    </string>
    <string id="rax_ammo_check_display_mode_lst_dm_numeric">
        <text>Numeric Only</text>
    </string>
    <string id="rax_ammo_check_display_mode_lst_dm_both">
        <text>Text + Numeric</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_minimalist_bar">
        <text>Minimalist Bar Display</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_minimalist_bar_desc">
        <text>Replace the ammo message with a minimalist 6-segment block bar (filled blocks for remaining ammo) instead of text or numbers. Handles "1 in the chamber" (+), empty/no magazine (X______), jammed (X) and grenade (o) too. Overrides Display Mode. Colored Messages still tints the bar by ammo level.</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_custom_render">
        <text>Custom Text Render</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_custom_render_desc">
        <text>Draw the ammo message as a styled HUD overlay (selectable font, size and screen position, with a drop shadow) instead of the default top-left pickup line. Works with Colored Messages, Display Mode, Minimalist Bar, ammo type/tag and the second highlight line.</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_render_font_family">
        <text>Render Font</text>
    </string>
    <string id="ui_mcm_rax_ammo_check_render_font_family_desc">

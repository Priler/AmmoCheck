-- AmmoCheck Weapon Exclusion Lists
-- This file contains weapon configurations for special animation handling.
-- 
-- HOW TO ADD WEAPONS:
-- 1. Find the weapon section name in configs (e.g., "wpn_mp133")
-- 2. Add it to the appropriate list below
-- 3. The lookup uses LONGEST PREFIX matching:
--    - "wpn_mp133" matches "wpn_mp133", "wpn_mp133_camo", "wpn_mp133_tactical"
--    - More specific entries override shorter ones:
--      ["wpn_aps"] = { anim = "anm_bore" }      -- matches wpn_aps, wpn_aps_gold
--      ["wpn_aps_bas"] = { anim = "anm_reload" } -- matches wpn_aps_bas (takes priority)
--
-- HOW TO CUSTOMIZE:
-- - delay: Time in seconds between anm_open and anm_close
-- - anim: Animation name to play
-- - sound: Sound parameter from weapon config
--
-- DEBUG MODE KEYS (works only when debug mode is enabled in MCM):
-- Numpad +/- = Adjust bolt/pump animation delay in real-time
-- Numpad /   = Play anm_bore animation
-- Numpad .   = Play anm_idle animation
-- Numpad *   = List all animations for current weapon
-- ============================================

local string_find = string.find

-- Cache for lookup results (cleared on game load)
config_cache = {}


--[ Per-weapon ammo check override ]--
-- TOP-PRIORITY override. Bypasses all other animation logic (path A, fake reload,
-- bolt cycle, lists, fallback) and forces the chosen behavior. Use when none of the
-- other heuristics produce the right visual for a specific weapon.
--
-- DEFAULT-mode fields (used when MCM "Force Bolt Cycle for External-Mag Rifles" is OFF,
-- or when the entry has no force_* counterpart). Pick ONE:
--   anim = "anm_name", sound = "snd_param"   -- force-play this animation
--   fake_reload = true                       -- standard fake-reload path (anm_reload + empty-mag handling)
--   fallback = true                          -- no animation, route to fake_reload_fallback (lower / hide)
--
-- FORCE-mode fields (used INSTEAD of the default fields when MCM "Force Bolt Cycle for
-- External-Mag Rifles" is ON, and at least one force_* is set on the entry). Pick ONE:
--   force_anim = "anm_name", force_sound = "snd_param"
--   force_fake_reload = true
--   force_fallback = true
--
-- Longest-prefix match wins (so wpn_l96a1_tactical can override wpn_l96a1).
ammo_check_override = {
    -- For wpn_l96a1 the engine's anm_reload visual is itself a bolt cycle, so neither
    -- fake reload nor explicit bolt cycle look right by default.

    -- this weapon's anm_reload plays cycle bolt
    -- and anm_reload_empty plays full external mag reload
    -- (including bolt cycle before/after ejecting/inserting the mag)
    -- ...
    -- anm_ammo_check plays the cycle bolt as well (so there's no proper ammo check animation)
    ["wpn_l96a1"] = {
        anim = "anm_ammo_check", sound = "snd_ammo_check",
        force_anim = "anm_ammo_check", force_sound = "snd_ammo_check", -- force is for "Force Bolt Cycle External Mag"
    },

    ["wpn_toz106_m1"] = { anim = "anm_bore", sound = "snd_bore", delay = 0.6 },
    ["wpn_bm16"] = { anim = "anm_bore", sound = "snd_bore" },
    ["wpn_saiga12s"] = { anim = "anm_bore", sound = "snd_bore" },

    -- Other shapes you can use for any weapon:
    -- ["wpn_example_a"] = { fake_reload = true },                       -- default uses standard fake reload
    -- ["wpn_example_b"] = { fallback = true },                          -- default uses fake_reload_fallback (lower / hide)
    -- ["wpn_example_c"] = { anim = "anm_bore", sound = "snd_bore",      -- mixed: anim default, force-mode falls back to fallback
    --                       force_fallback = true },
}


--[ Break-action shotguns ]--
-- These use a custom animation (usually anm_bore or anm_idle)
-- Format: [prefix] = { anim = "animation_name", sound = "sound_param" }
break_action_shotguns = {
    ["wpn_toz34"] = { anim = "anm_bore", sound = "snd_bore" }, -- badass Chimera Hunter ammo check animation

    -- ["wpn_izh43"] = { anim = "anm_bore", sound = "snd_bore" },
}


--[ Bolt-action rifles ]--
-- These play anm_open -> delay -> anm_close (bolt cycle), or a custom single-shot anim.
-- Format: [prefix] = { delay = seconds_between_open_and_close }
--     OR: [prefix] = { anim = "anm_name", sound = "snd_param", delay = fallback_seconds }
-- Optional flags:
--   override_inspect = true   -- ignore anm_ammo_check inspect anim and force bolt cycle
--                                (use when the weapon defines both, but bolt cycle looks better;
--                                only applies to internal-mag entries).
--   external_mag = true       -- this bolt-action variant has a detachable / external magazine.
--                                Default behavior: SKIP the explicit anm_open/anm_close cycle
--                                and fall through to fake reload (engine's anm_reload).
--                                When MCM "force_bolt_cycle_external_mag" is ON, the explicit
--                                bolt cycle plays anyway (delay/anim/sound from this entry).
--                                The regular fake_reload_bolt_cycle toggle does NOT affect
--                                external_mag entries (the force option does).
bolt_action_rifles = {
    ["wpn_k98"] = { delay = 1.3, override_inspect = true }, -- has both inspect anim and bolt cycle; prefer bolt cycle
    ["wpn_shiv"] = { delay = 1.2 },
    ["wpn_obrez"] = { delay = 1.2 }, -- mosin obrez
    ["wpn_mosin_carbine"] = { delay = 1.2 }, -- mosin carbine (from Kmack "Mosin Trio" mod)
    ["wpn_mosin_k"] = { delay = 1.2 }, -- mosin (from Kmack "Mosin Trio" mod)
    -- ["wpn_mosin_k"] = { anim = "anm_bore", sound = "snd_bore", delay = 0.8 }, -- mosin (Kmack); use anm_bore (single-shot cycle) to avoid bolt snap-back; delay is fallback if anm_bore is missing

    ["wpn_sks_molot"] = { delay = 1.3 },

    -- ["wpn_winchester1873"] = { delay = 1.2 },

    -- External-mag bolt-action variants. Default: fake reload (anm_reload).
    -- With MCM "force_bolt_cycle_external_mag" ON: play explicit bolt cycle using the
    -- delay/anim below. Longer prefixes here override shorter base prefixes (e.g. wpn_k98).
    ["wpn_l96a1"] = { external_mag = true, delay = 0.7 },
    ["wpn_remington700"] = { external_mag = true, delay = 0.7 },
    ["wpn_k98_mauser_kit"] = { external_mag = true, delay = 1.3 },   -- detachable-mag K98 variant
    ["wpn_k98_mod_silen98"] = { external_mag = true, delay = 1.3 },  -- silenced detachable-mag K98 variant

    -- ["wpn_springfield"] = { delay = 0.7 },
    -- ["wpn_m24"] = { delay = 0.8 },
    -- ["wpn_cz550"] = { delay = 0.7 },
    -- ["wpn_scout"] = { delay = 0.6 },
    -- ["wpn_sks"] = { delay = 0.5 },
    -- ["wpn_sv98"] = { delay = 0.7 },
    -- ["wpn_svd"] = { delay = 0.6 },
    ["wpn_mosin"] = { delay = 1.2 }, -- vanilla Mosin: enable explicit bolt cycle
}



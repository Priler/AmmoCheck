eject_shell_exclude = {
    ["wpn_ks23"] = true, -- doesn't use rack slide animation
    ["wpn_mp155"] = true, -- doesn't use rack slide animation
    ["wpn_ithacam37"] = true, -- doesn't use rack slide animation


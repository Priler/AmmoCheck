    [key_bindings.kBACK] = true,
    [key_bindings.kL_STRAFE] = true,
    [key_bindings.kACCEL] = true,
    [key_bindings.kR_STRAFE] = true
}

local weapon_hidden = false

-- Mags Redux reloads from its OWN on_before_key_press handler, calling actor_on_weapon_reload
-- directly, so it ignores our flags.ret_value. To fully block reload during the check window we
-- also unregister that handler (same trick One-Key uses) and restore it afterwards. Guarded by
-- ac_mags_suppressed so we register/unregister exactly once. No-op when Mags is absent.
local function set_ac_mags_suppressed(suppress)
    if not (magazines and magazines.on_key_press) then return end
    if suppress and not ac_mags_suppressed then
        UnregisterScriptCallback("on_before_key_press", magazines.on_key_press)
        ac_mags_suppressed = true
    elseif (not suppress) and ac_mags_suppressed then
        RegisterScriptCallback("on_before_key_press", magazines.on_key_press)
        ac_mags_suppressed = false
    end
end

-- restore the Mags handler and stop blocking; safe to call repeatedly
local function ac_end_reload_block()
    ac_anim_block_until = 0
    RemoveTimeEvent("ac_mags_block", "arm")
    RemoveTimeEvent("ac_mags_block", "restore")
    set_ac_mags_suppressed(false)
end

-- True when One-Key is on AND the pressed key is the very key One-Key drives its tap/hold multiplex
-- with. In that (and only that) case the standalone ammo-check key must yield so the two do not both
-- fire. A standalone key bound to anything else keeps working normally even with One-Key enabled.
local function onekey_owns_key(key)
    return onekey_enabled and onekey_key and onekey_key ~= DIK_keys.DIK_ESCAPE and key == onekey_key
end

-- Block the reload bind while a check animation is playing, so a reload cannot cut it short.
-- The window is armed in check_Ammo; the weapon being non-idle means the animation is actually
-- running (message-only checks keep it idle and so are never blocked). ret_value=false consumes
-- the press. One-Key, when enabled, owns the reload bind separately; this is for the default path.
function on_before_key_press(key, bind, dis, flags)
    -- No-magazine path-A guard: when an ammo check on the current weapon would use the no-magazine
    -- fallback (lower/hide), consume the ammo-check key here so the ENGINE weapon-inspect bound to it
    -- never starts. check_Ammo can only mutate that inspect, not cancel it, so blocking it up front is
    -- the only way the fallback actually shows. Yields only when the key collides with One-Key's key.
    if not onekey_owns_key(key) and mcm_key and mcm_key ~= DIK_keys.DIK_ESCAPE and key == mcm_key then
        local wpn = db.actor and db.actor:active_item()
        if wpn and IsWeapon(wpn) and ac_should_block_inspect_no_mag(wpn, wpn:section()) then
            flags.ret_value = false
        end
    end

    if time_global() >= ac_anim_block_until then return end  -- window is the master gate
    bind = bind or dik_to_bind(key)
    if bind ~= key_bindings.kWPN_RELOAD then return end
    -- only block while an animation is actually running: path A (native inspect), a fake reload,
    -- or any path that put the weapon in a non-idle HUD state. Message-only checks stay idle and
    -- set no flag, so they never block reload even though the window is armed.
    local wpn = db.actor and db.actor:active_item()
    local anim_playing = ac_pending_inspect_anim_playing or is_fake_reload
        or (wpn and IsWeapon(wpn) and wpn:get_state() ~= 0)
    if anim_playing then
        flags.ret_value = false
    end
end

-- Debug numpad keys live in their OWN on_key_press handler, registered once in on_game_start and
-- never touched by the key-mode (un)register dance below. The mode-specific on_key_press handler is
-- unregistered in Hold mode (default), which would otherwise kill these keys.
function on_key_press_debug(key)
    if not debug_mode then return end
    if numpad_states[key] then
        debug_test_state(numpad_states[key])
        return
    end
    if key == DIK_keys.DIK_MULTIPLY then debug_list_animations() return end   -- numpad * lists animations
    if key == DIK_keys.DIK_ADD      then debug_adjust_delay(0.1) return end   -- numpad + increases delay
    if key == DIK_keys.DIK_SUBTRACT then debug_adjust_delay(-0.1) return end  -- numpad - decreases delay
    if key == DIK_keys.DIK_DIVIDE   then debug_play_animation("anm_bore") return end  -- numpad / anm_bore
    if key == DIK_keys.DIK_DECIMAL  then debug_play_animation("anm_idle") return end  -- numpad . anm_idle
end

function on_key_press(key)
    local bind = dik_to_bind(key)
    if weapon_hidden and not direction_keys[bind] then
        weapon_hidden = false
    end

    -- The standalone ammo-check key keeps working with One-Key on; only yield if it is the same key
    -- One-Key drives (else both would fire the check on one press).
    if onekey_owns_key(key) then return end
    if mcm_key == DIK_keys.DIK_ESCAPE then return end  -- unbound (set to none via Unbind / ESC)
    if key ~= mcm_key then return end
    -- the simple ammo-check key may not share the Reload bind: it would fire on every reload and
    -- the two animations would fight. Ignore it here; reload-triggered checks are the One-Key job.
    if dik_to_bind(key) == key_bindings.kWPN_RELOAD then return end
    if not mcm_keybinds then
        check_Ammo()
        return
    end
    -- modifier 0 means "No Modifier": fire regardless of held keys so checking
    -- works while running (Shift). get_mod_key(0) would instead require that no
    -- modifier is held, which blocks the check when Shift/Ctrl/Alt is down.
    if not (modifier == 0 or ui_mcm.get_mod_key(modifier)) then return end
    -- Single-press mode calls check_Ammo directly instead of ui_mcm.simple_press: that helper treats a
    -- held movement/action key (sprint, crouch, lean, walk) as a key-combo and rejects the press, which
    -- would block an ammo check while moving. Double-tap / hold keep their MCM helpers.
    if mode == 0 then
        check_Ammo()
    else
        modes[mode]["function"](key)
    end
end

function on_key_hold(key)
    if onekey_owns_key(key) then return end  -- yield only on a real key collision with One-Key
    if mcm_key == DIK_keys.DIK_ESCAPE then return end  -- unbound
    if key ~= mcm_key then return end
    if dik_to_bind(key) == key_bindings.kWPN_RELOAD then return end  -- reload bind reserved; use One-Key
    if modifier == 0 or ui_mcm.get_mod_key(modifier) then
        modes[mode]["function"](key)
    end
end

-- message display
local function display_message(message, clr)
    if not message then return false end
    if not show_message then return false end
    actor_menu.set_msg(1, message, msg_duration, clr)
    return true
end

-- ### CUSTOM HUD RENDER (inspired/taken from Cheeki Numbers mod by Cheeki Breeki)
-- Styled on-screen message drawn over the HUD instead of the actor_menu message line.
-- Fonts": CUIScriptWnd subclass + utils_xml.get_hud_xml():InitTextWnd + SetTextComplexMode
-- (for %c color tags) + engine font getters + 1px black drop-shadow + AddDialogToRender.

-- Font-family table (stores getter FUNCTIONS, called later).
local AC_FONT_FAMILIES = {
    -- 0: Graffiti           small             medium                large                 xlarge                 large+
    { GetFontLetterica16Russian, GetFontGraffiti19Russian, GetFontGraffiti22Russian, GetFontGraffiti32Russian, GetFontLetterica25Russian },
    -- 1: Letterica
    { GetFontLetterica16Russian, GetFontLetterica18Russian, GetFontLetterica25Russian, GetFontLetterica25Russian, GetFontLetterica25Russian },
    -- 2: System
    { GetFontSmall, GetFontMedium, GetFontDI, GetFontGraffiti32Russian, GetFontLetterica25Russian },
    -- 3: Letterica Pure
    { GetFontLetterica16Russian, GetFontLetterica18Russian, GetFontLetterica25, GetFontLetterica25, GetFontLetterica25 },
}

-- returns a font getter FUNCTION (call it to get the font object)
local function ac_get_font_func()
    local fam = clamp(render_font_family or 0, 0, 3)
    local sz  = clamp(render_font_size or 3, 1, 5)
    local fam_t = AC_FONT_FAMILIES[fam + 1] or AC_FONT_FAMILIES[1]
    return fam_t[sz] or GetFontGraffiti22Russian
end

-- decompose a packed ARGB int (GetARGB) into a "%c[a,r,g,b]" complex-text color tag
local function argb_to_tag(clr)
    if not clr then return "%c[255,255,255,255]" end
    local a = bit.band(bit.rshift(clr, 24), 0xFF)
    local r = bit.band(bit.rshift(clr, 16), 0xFF)
    local g = bit.band(bit.rshift(clr, 8), 0xFF)
    local b = bit.band(clr, 0xFF)
    return string_format("%%c[%d,%d,%d,%d]", a, r, g, b)
end

local AC_SHADOW_TAG = "%c[255,0,0,0]"  -- opaque black, for the drop shadow (%c complex-mode lines)
local AC_SHADOW_ARGB = GetARGB(255, 0, 0, 0)  -- opaque black, for SetTextColor (plain single-color lines)

-- Build the shadow copy of a (possibly multi-color) string: keep every %c[a,r,g,b] tag
-- in place but force R,G,B to 0 while PRESERVING alpha and the exact digit count. This
-- keeps the shadow string the same character length as the foreground (so center/left
-- alignment measures identical widths and the two layers line up), but renders solid black.
local function ac_blacken_tags(s)
    return (s:gsub("%%c%b[]", function(tag)
        local inside = tag:sub(4, -2)  -- strip leading "%c[" and trailing "]"
        local parts = {}
        for n in inside:gmatch("[^,]+") do parts[#parts + 1] = n end
        if #parts == 4 then
            parts[2] = string.rep("0", #parts[2])  -- R, same width
            parts[3] = string.rep("0", #parts[3])  -- G
            parts[4] = string.rep("0", #parts[4])  -- B
            return "%c[" .. table.concat(parts, ",") .. "]"
        end
        return tag
    end))
end
local AC_RENDER_W = 800                -- text wnd width in 1024x768 virtual UI space
local AC_LINE_SPACING = 20             -- vertical gap between line 1 and line 2

class "ac_msg_overlay" (CUIScriptWnd)

function ac_msg_overlay:__init() super()
    self.xml = utils_xml.get_hud_xml()       -- shared pre-parsed HUD xml
    self.font_func = ac_get_font_func()
    self.visible_until = 0
    self.added = false
    self.registered = false
    self.l1 = self:make_line()
    self.l2 = self:make_line()
    -- dedicated controls for Combined mode: main text + ammo tag rendered as two
    -- side-by-side SINGLE-color (SetTextColor, no %c) controls, so the engine's
    -- center/right alignment width quirk with mid-string %c tags can't open a gap.
    self.l1main = self:make_line()
    self.l1tag  = self:make_line()
end

-- build one text control (clones a vanilla HUD label node, inherits a usable skin).
-- Shadow is created FIRST so the colored text (attached later) renders on top of it.
function ac_msg_overlay:make_line()
    local s = self.xml:InitTextWnd("companion_list:slot:distance", self)
    s:SetFont(self.font_func())
    _shared_vec_render:set(AC_RENDER_W, 50) ; s:SetWndSize(_shared_vec_render)
    s:SetTextComplexMode(true)
    _shared_vec_render:set(-1000, -1000) ; s:SetWndPos(_shared_vec_render)

    local w = self.xml:InitTextWnd("companion_list:slot:distance", self)
    w:SetFont(self.font_func())
    _shared_vec_render:set(AC_RENDER_W, 50) ; w:SetWndSize(_shared_vec_render)
    w:SetTextComplexMode(true)
    _shared_vec_render:set(-1000, -1000) ; w:SetWndPos(_shared_vec_render)

    return { text = w, shadow = s }
end

-- resolve alignment + base x/y for the current render_position (1024x768 virtual space).
-- CGameFont alignment enum: alLeft=0, alRight=1, alCenter=2.
-- Near-cursor (4-7) positions are relative to the crosshair / screen center (512,384),
-- offset by render_cursor_gap. AC_CURSOR_VPAD nudges the text so it sits clear of center.
local AC_CURSOR_CX = 512
local AC_CURSOR_CY = 384
local AC_CURSOR_VPAD = 24
-- pos_override (optional): a render-position index that wins over the configured render_position,
-- so a sibling feature can pin its message somewhere (e.g. fire mode forcing screen bottom)
local function ac_render_layout(pos_override)
    local p = pos_override or render_position or 3
    local gap = render_cursor_gap or 80
    local cx_left = (1024 - AC_RENDER_W) / 2  -- x for a centered full-width line
    if p == 0 then     -- top-left
        return 0, 20, 40
    elseif p == 1 then -- top-right
        return 1, 1024 - 20 - AC_RENDER_W, 40
    elseif p == 2 then -- center
        return 2, cx_left, 300
    elseif p == 3 then -- bottom-center
        return 2, cx_left, 600
    elseif p == 4 then -- near cursor, left  (right-aligned, ends gap px left of center)
        return 1, (AC_CURSOR_CX - gap) - AC_RENDER_W, AC_CURSOR_CY - 12
    elseif p == 5 then -- near cursor, top   (centered, sits gap px above center)
        return 2, cx_left, AC_CURSOR_CY - gap - AC_CURSOR_VPAD
    elseif p == 6 then -- near cursor, right (left-aligned, starts gap px right of center)
        return 0, AC_CURSOR_CX + gap, AC_CURSOR_CY - 12
    elseif p == 7 then -- near cursor, bottom (centered, sits gap px below center)
        return 2, cx_left, AC_CURSOR_CY + gap
    elseif p == 8 then -- bottom-right
        return 1, 1024 - 20 - AC_RENDER_W, 600
    elseif p == 9 then -- bottom-left
        return 0, 20, 600
    elseif p == 10 then -- screen bottom (centered, lower than bottom-center; sibling-only override)
        return 2, cx_left, 700
    end
    return 2, cx_left, 600
end

-- place a {text, shadow} line at (x, y) with given alignment and color tag
function ac_msg_overlay:place_line(line, str, ctag, align, x, y)
    line.text:SetTextAlignment(align)
    line.shadow:SetTextAlignment(align)
    local fg = ctag .. str
    line.text:SetText(fg)
    -- shadow = same string, every color tag forced to black (alpha + length preserved),
    -- so it stays a solid-black silhouette AND keeps identical width for alignment.
    line.shadow:SetText(ac_blacken_tags(fg))
    _shared_vec_render:set(x, y)         ; line.text:SetWndPos(_shared_vec_render)
    _shared_vec_render:set(x + 1, y + 1) ; line.shadow:SetWndPos(_shared_vec_render)
end

function ac_msg_overlay:hide_line(line)
    _shared_vec_render:set(-1000, -1000)
    line.text:SetWndPos(_shared_vec_render)
    line.shadow:SetWndPos(_shared_vec_render)
end

-- configure a {text, shadow} line as a PLAIN single-color, left-aligned, auto-width
-- control (no %c tags). SetTextColor governs the whole string, so the alignment width
-- quirk that affects mid-string %c tags cannot apply. GetWidth() is valid afterwards.
function ac_msg_overlay:set_plain(line, str, clr)
    line.text:SetTextComplexMode(false)
    line.shadow:SetTextComplexMode(false)
    line.text:SetTextAlignment(0)        -- alLeft: measure/position from the left edge
    line.shadow:SetTextAlignment(0)
    line.text:SetText(str)
    line.shadow:SetText(str)
    line.text:SetTextColor(clr)
    line.shadow:SetTextColor(AC_SHADOW_ARGB)
    line.text:AdjustWidthToText()        -- shrink WndSize to content so GetWidth() is exact
    line.shadow:AdjustWidthToText()
end

-- place a plain line's left edge at (x, y) with the +1,+1 shadow
function ac_msg_overlay:place_plain(line, x, y)
    _shared_vec_render:set(x, y)         ; line.text:SetWndPos(_shared_vec_render)
    _shared_vec_render:set(x + 1, y + 1) ; line.shadow:SetWndPos(_shared_vec_render)
end

-- Combined mode: main text (level color) + ammo tag (ammo-type color) on ONE line,
-- as two side-by-side single-color controls. Measured and laid out as a group so it
-- honors the render position/alignment without any mid-string %c gap.
local AC_COMBINED_GAP = 6  -- px between main text and tag (1024x768 virtual space)
function ac_msg_overlay:show_combined(main_str, main_clr, tag_str, tag_clr, duration, pos)
    if not main_str or main_str == "" then return end
    local align, x, y1 = ac_render_layout(pos)

    self:set_plain(self.l1main, main_str, main_clr or clr06_White)
    self:set_plain(self.l1tag,  tag_str,  tag_clr or clr06_White)
    local main_w = self.l1main.text:GetWidth()
    local tag_w  = self.l1tag.text:GetWidth()
    local total_w = main_w + AC_COMBINED_GAP + tag_w

    local group_left
    if align == 2 then        -- center: group centered on the box midpoint
        group_left = (x + AC_RENDER_W / 2) - total_w / 2
    elseif align == 1 then    -- right: group right edge at the box right edge
        group_left = (x + AC_RENDER_W) - total_w
    else                      -- left: group starts at the box left edge
        group_left = x
    end

    self:place_plain(self.l1main, group_left, y1)
    self:place_plain(self.l1tag,  group_left + main_w + AC_COMBINED_GAP, y1)

    -- combined uses its own controls; clear the %c single-line controls
    self:hide_line(self.l1)
    self:hide_line(self.l2)
    self:hide_segs()

    self.visible_until = time_global() + math_floor((duration or 2) * 1000)
    if not self.added then
        local hud = get_hud()
        if hud then
            hud:AddDialogToRender(self)
            self.added = true
        end
    end
    if not self.registered then
        RegisterScriptCallback("actor_on_update", self)
        self.registered = true
    end
end

-- Render up to N single-color segments side by side as ONE group, each with its own color.
-- Same technique as show_combined (set_plain controls, no mid-string %c), so the center/right
-- alignment width quirk never applies. segments = { { str=, clr=, gap= }, ... }; gap is the
-- pixel space placed BEFORE that segment (0 makes it butt against the previous one).
function ac_msg_overlay:show_segments(segments, duration, pos)
    local segs = {}
    for i = 1, #segments do
        local s = segments[i]
        if s and s.str and s.str ~= "" then segs[#segs + 1] = s end
    end
    if #segs == 0 then return end

    -- lazily grow a control pool to match the segment count
    self.seg_lines = self.seg_lines or {}
    while #self.seg_lines < #segs do
        self.seg_lines[#self.seg_lines + 1] = self:make_line()
    end

    local align, x, y1 = ac_render_layout(pos)

    local widths = {}
    local total_w = 0
    for i = 1, #segs do
        self:set_plain(self.seg_lines[i], segs[i].str, segs[i].clr or clr06_White)
        widths[i] = self.seg_lines[i].text:GetWidth()
        total_w = total_w + widths[i] + (i > 1 and (segs[i].gap or 0) or 0)
    end

    local group_left
    if align == 2 then
        group_left = (x + AC_RENDER_W / 2) - total_w / 2
    elseif align == 1 then
        group_left = (x + AC_RENDER_W) - total_w
    else
        group_left = x
    end

    local cur = group_left
    for i = 1, #segs do
        if i > 1 then cur = cur + (segs[i].gap or 0) end
        self:place_plain(self.seg_lines[i], cur, y1)
        cur = cur + widths[i]
    end
    for i = #segs + 1, #self.seg_lines do
        self:hide_line(self.seg_lines[i])
    end

    -- clear the other modes' controls
    self:hide_line(self.l1)
    self:hide_line(self.l2)
    self:hide_line(self.l1main)
    self:hide_line(self.l1tag)

    self.visible_until = time_global() + math_floor((duration or 2) * 1000)
    if not self.added then
        local hud = get_hud()
        if hud then
            hud:AddDialogToRender(self)
            self.added = true
        end
    end
    if not self.registered then
        RegisterScriptCallback("actor_on_update", self)
        self.registered = true
    end
end

function ac_msg_overlay:show(message, clr, line2, line2_clr, duration, pos)
    if not message or message == "" then return end
    local align, x, y1 = ac_render_layout(pos)

    self:place_line(self.l1, message, argb_to_tag(clr), align, x, y1)

    if line2 and line2 ~= "" then
        self:place_line(self.l2, line2, argb_to_tag(line2_clr or clr), align, x, y1 + AC_LINE_SPACING)
    else
        self:hide_line(self.l2)
    end

    -- not in combined mode: clear its dedicated controls
    self:hide_line(self.l1main)
    self:hide_line(self.l1tag)
    self:hide_segs()

    self.visible_until = time_global() + math_floor((duration or 2) * 1000)

    if not self.added then
        local hud = get_hud()
        if hud then
            hud:AddDialogToRender(self)
            self.added = true
        end
    end
    if not self.registered then
        RegisterScriptCallback("actor_on_update", self)
        self.registered = true
    end
end

function ac_msg_overlay:hide_segs()
    if self.seg_lines then
        for i = 1, #self.seg_lines do self:hide_line(self.seg_lines[i]) end
    end
end

function ac_msg_overlay:hide()
    self:hide_line(self.l1)
    self:hide_line(self.l2)
    self:hide_line(self.l1main)
    self:hide_line(self.l1tag)
    self:hide_segs()
    self.visible_until = 0
    if self.added then
        local hud = get_hud()
        if hud then hud:RemoveDialogToRender(self) end
        self.added = false
    end
    if self.registered then
        UnregisterScriptCallback("actor_on_update", self)
        self.registered = false
    end
end

-- self-expire: hide when the display duration elapses (callback object form)
function ac_msg_overlay:actor_on_update()
    if self.visible_until > 0 and time_global() >= self.visible_until then
        self:hide()
    end
end

-- lazily create the singleton overlay (after a font/position change it is dropped and rebuilt)
local function get_ac_overlay()
    if not ac_overlay then
        ac_overlay = ac_msg_overlay()
    end
    return ac_overlay
end

-- drop the overlay so the next show() rebuilds it with current font settings
local function reset_ac_overlay()
    if ac_overlay then
        ac_overlay:hide()
        ac_overlay = nil
    end
end

-- ammo type classification
-- returns: type_key, display_tag
local function classify_ammo_type(section)
    if not section then return "unknown", nil end
    
    -- check cache first
    local cached = ammo_type_cache[section]
    if cached then
        return cached.type, cached.tag
    end
    
    local sec_lower = string_lower(section)
    local result_type = "unknown"
    local result_tag = nil
    
    -- AP (Armor Piercing): ap, pp, pbp, bp, 7h14, 7n, sp10, ss190, dart, barrikada
    if string_find(sec_lower, "_ap") 
       or string_find(sec_lower, "_bp") 
       or string_find(sec_lower, "_pbp")
       or string_find(sec_lower, "_pp")
       or string_find(sec_lower, "7h14")
       or string_find(sec_lower, "7n")
       or string_find(sec_lower, "sp10")
       or string_find(sec_lower, "ss190")
       or string_find(sec_lower, "_dart")
       or string_find(sec_lower, "barrikada") then
        result_type, result_tag = "ap", "(AP)"
    
    -- HP (Hollow Point): hp, jhp, hydro, sp (soft point)
    elseif string_find(sec_lower, "_hp") 
       or string_find(sec_lower, "jhp")
       or string_find(sec_lower, "hydro")
       or string_find(sec_lower, "_sp_") then
        result_type, result_tag = "hp", "(HP)"
    
    -- tracer
    elseif string_find(sec_lower, "_t_") 
       or string_find(sec_lower, "_tracer") then
        result_type, result_tag = "tracer", "(T)"
    
    -- incendiary/fire: fire, zp
    elseif string_find(sec_lower, "fire") 
       or string_find(sec_lower, "_zp") then
        result_type, result_tag = "fire", "(I)"
    
    -- subsonic
    elseif string_find(sec_lower, "sub") then
        result_type, result_tag = "sub", "(SUB)"
    
    -- match/enhanced: ep, pmm, pab9, 7h1
    elseif string_find(sec_lower, "_ep")
       or string_find(sec_lower, "_pmm")
       or string_find(sec_lower, "pab9")
       or string_find(sec_lower, "7h1") then
        result_type, result_tag = "enhanced", "(+)"
    
    -- slug (shotgun): slug, zhekan, shrapnel, eco
    elseif string_find(sec_lower, "slug")
       or string_find(sec_lower, "zhekan") 
       or string_find(sec_lower, "shrapnel")
       or string_find(sec_lower, "_eco") then
        result_type, result_tag = "slug", "(SL)"
    
    -- buckshot: buck, shot (but not shrapnel which is slug)
    elseif string_find(sec_lower, "buck") 
       or (string_find(sec_lower, "_shot") and not string_find(sec_lower, "shrapnel")) then
        result_type, result_tag = "buck", "(BK)"
    
    -- FMJ/ball/standard: fmj, ball, ps, p, ss195
    elseif string_find(sec_lower, "_fmj") 
       or string_find(sec_lower, "_ball")
       or string_find(sec_lower, "_ps")
       or string_match(sec_lower, "_p$")
       or string_find(sec_lower, "ss195") then
        result_type, result_tag = "fmj", "(FMJ)"
    end
    
    -- store in cache
    ammo_type_cache[section] = { type = result_type, tag = result_tag }
    return result_type, result_tag
end

-- get color for ammo type
local function get_ammo_type_color(ammo_type)
    return ammo_type_colors[ammo_type]
end

-- remove duplicate suffix if both ammo type and tag are shown from ammo name
-- e.g. "9x19 HP" + "(HP)" -> "9x19", ".300 Blackout MAI AP" + "(AP+)" -> ".300 Blackout MAI"
local function remove_duplicate_suffix(ammo_name, tag)
    if not ammo_name or not tag then return ammo_name end

    -- extract tag content without parentheses (e.g., "HP" from "(HP)", "AP+" from "(AP+)")
    local tag_content = string_match(tag, "%((.+)%)")
    if not tag_content then return ammo_name end

    -- candidates to strip from the name end, longest first: the full tag ("AP+") and, for an enhanced
    -- "+"-tag, the bare type without the plus ("AP") - so a name that ends in just the type letters
    -- (".300 Blackout MAI AP") still drops the redundant suffix when the tag is "(AP+)".
    local candidates = { tag_content }
    local bare = string_match(tag_content, "^(.-)%+$")  -- "AP" from "AP+"
    if bare and bare ~= "" then candidates[#candidates + 1] = bare end

    for i = 1, #candidates do
        local suf = candidates[i]
        local name_len = #ammo_name
        local suf_len = #suf
        -- need at least space + suffix; ends with " SUF" (case-insensitive)
        if name_len >= suf_len + 1 then
            local suffix_start = name_len - suf_len
            local potential_suffix = string_sub(ammo_name, suffix_start + 1)
            local char_before = string_sub(ammo_name, suffix_start, suffix_start)
            if char_before == " " and string_lower(potential_suffix) == string_lower(suf) then
                return string_sub(ammo_name, 1, suffix_start - 1)
            end
        end
    end

    return ammo_name
end

-- classify ammo type based on display name
-- returns: type_key, display_tag
local function classify_ammo_by_name(ammo_name)
    if not ammo_name or ammo_name == "" then return "unknown", nil end
    
    local name_lower = string_lower(ammo_name)
    
    -- HP variants (LRN / LRNPC lead round-nose tagged HP)
    if string_match(name_lower, " hp$") or string_match(name_lower, "hp$")
       or string_find(name_lower, "jhp") or string_find(name_lower, "hydro")
       or string_find(name_lower, "lrn") then
        return "hp", "(HP)"
    end
    
    -- AP variants
    if string_match(name_lower, " ap$") or string_match(name_lower, "ap$")
       or string_match(name_lower, " bp$") or string_match(name_lower, "bp$")
       or string_match(name_lower, " pbp$") or string_find(name_lower, " pp")
       or string_find(name_lower, "sp10") or string_find(name_lower, "ss190") then
        return "ap", "(AP)"
    end
    
    -- 7N series (Russian AP designations - check separately)
    if string_find(name_lower, "7n") then
        return "ap", "(AP)"
    end
    
    -- tracer
    if string_find(name_lower, "tracer") or string_match(name_lower, " t$") then
        return "tracer", "(T)"
    end
    
    -- Incendiary
    if string_find(name_lower, "fire") or string_find(name_lower, "incend")
       or string_find(name_lower, " zp") then
        return "fire", "(I)"
    end
    
    -- subsonic
    if string_find(name_lower, "sub") then
        return "sub", "(SUB)"
    end
    
    -- Enhanced
    if string_match(name_lower, " ep$") or string_find(name_lower, "pmm")
       or string_find(name_lower, "match") then
        return "enhanced", "(+)"
    end
    
    -- Slug
    if string_find(name_lower, "slug") or string_find(name_lower, "zhekan")
       or string_find(name_lower, "shrapnel") or string_find(name_lower, "eco") then
        return "slug", "(SL)"
    end
    
    -- Buckshot
    if string_find(name_lower, "buck") or string_find(name_lower, "shot") then
        return "buck", "(BK)"
    end
    
    -- FMJ/Standard (PST ball tagged FMJ; exclude PSTM so the modernized round isn't swept in)
    if string_find(name_lower, "fmj") or string_find(name_lower, "ball")
       or string_match(name_lower, " ps$") or string_match(name_lower, " p$")
       or (string_find(name_lower, "pst") and not string_find(name_lower, "pstm")) then
        return "fmj", "(FMJ)"
    end
    
    return "unknown", nil
end

-- ArtiGrok Ballistics (optional) marks its enhanced ammo variants with a trailing "<TYPE>+" on the
-- SHORT name (".45 HP+", ".300 AP+", ".300 FMJ+"), where the '+' is the signature. The FULL name is the
-- descriptive one - either ".45 ACP 'Reaper' rounds (HP+)" (with a parenthetical) or ".300 Blackout MAI
-- AP rounds" (no parenthetical). Build the display from the FULL name (drop a trailing "(TAG+)" if any,
-- then a filler word like rounds / shells) and the tag from the short name's "<TYPE>+". Keying off the
-- short name's trailing '+' covers both naming styles; vanilla / other ammo never ends in '+', so this
-- is a no-op when the mod is absent. Returns: display_name, tag, type_key (nil when not an enhanced "+").
local ENHANCED_TAG_TYPE = {
    hp = "hp", ap = "ap", fmj = "fmj", slug = "slug", buck = "buck",
    sub = "sub", t = "tracer", i = "fire",
}
local function parse_enhanced_ammo(full_name, short_name)
    if not short_name or short_name == "" then return nil end
    local base = string_match(short_name, "(%a+)%+%s*$")  -- "AP" from ".300 AP+", "HP" from ".45 HP+"
    if not base then return nil end
    local tag = "(" .. base .. "+)"
    local type_key = ENHANCED_TAG_TYPE[string_lower(base)] or "enhanced"
    -- descriptive display name from the full name (fall back to the short name if missing)
    local name = (full_name and full_name ~= "" and full_name) or short_name
    name = string.gsub(name, "%s*%(%a+%+%)%s*$", "")  -- drop a trailing "(HP+)" if the full name has one
    name = string.gsub(name, "%s+[Rr]ounds?$", "")     -- drop trailing "rounds"
    name = string.gsub(name, "%s+[Ss]hells?$", "")     -- or "shells"
    name = string.gsub(name, "%s+$", "")
    if name == "" then name = short_name end
    return name, tag, type_key
end

-- classify a round, preferring the ArtiGrok enhanced naming, then the short name, then the section.
-- returns: type_key, tag (e.g. "(AP)"), display_name
local function classify_round(round_sec)
    if not round_sec then return nil, nil, nil end
    local name = gc(ui_item.get_sec_short_name(round_sec))
    if name == "" then name = nil end
    local enh_name, enh_tag, enh_type = parse_enhanced_ammo(gc(ui_item.get_sec_name(round_sec)), name)
    if enh_tag then return enh_type, enh_tag, enh_name end
    local atype, tag
    if name then atype, tag = classify_ammo_by_name(name) end
    if not tag then atype, tag = classify_ammo_type(round_sec) end
    return atype, tag, name
end

-- format ammo type string for display
-- display_round: ammo section for name display
-- tag_round: ammo section for tag classification
-- returns: formatted_string, ammo_type_key, tag_for_separate_line
local function format_ammo_type_string(display_round, tag_round)
    if not display_round and not tag_round then return "", nil, nil end
    
    local result = ""
    local separate_tag = nil

    -- classify the round (ArtiGrok enhanced full name, else short name, else section). prefer
    -- tag_round (magazine contents) for consistent classification across name + tag.
    local round_for_tag = tag_round or display_round
    local ammo_type, tag, ammo_name = classify_round(round_for_tag)

    -- get display name only if show_ammo_type is enabled
    local ammo_name_display = nil
    if show_ammo_type and ammo_name and ammo_name ~= "" then
        ammo_name_display = ammo_name
    end
    
    -- remove duplicate suffix if both ammo type and tag are shown
    if ammo_name_display and show_ammo_tag and tag then
        ammo_name_display = remove_duplicate_suffix(ammo_name_display, tag)
    end
    
    -- determine what to show and how to highlight
    --   mode 2 (separate): ammo name on line 1, tag on line 2
    --   mode 3 (combined): whole ammo chunk returned via separate_tag (the colored part);
    --                      main line stays clean so it keeps the ammo-level color
    --   mode 0/1 (none/whole): everything appended on one line (result)
    if show_ammo_tag and tag then
        -- tag is enabled - highlight applies to tag
        if highlight_ammo_mode == 2 then
            -- separate lines: keep line 1 as the level message; put BOTH the ammo name and tag
            -- together on line 2 (same chunk as combined mode, just on its own line)
            result = ""
            separate_tag = ammo_name_display and (ammo_name_display .. " " .. tag) or tag
        elseif highlight_ammo_mode == 3 then
            -- combined: full chunk (name + tag) carried as the colored part
            result = ""
            separate_tag = ammo_name_display and (ammo_name_display .. " " .. tag) or tag
        else
            -- none or whole: everything on one line
            if ammo_name_display then
                result = ammo_name_display .. " " .. tag
            else
                result = tag
            end
        end
    elseif show_ammo_type and ammo_name_display then
        -- tag disabled but ammo type enabled - highlight applies to ammo type name
        if highlight_ammo_mode == 2 or highlight_ammo_mode == 3 then
            -- separate lines / combined: name is the colored part
            result = ""
            separate_tag = ammo_name_display
        else
            -- single line
            result = ammo_name_display
        end
    end
    
    return result, ammo_type, separate_tag
end

-- Tarkov-like rough count: round to the nearest 5, then clamp to [5, max-5] so a nearly-full mag
-- never reads at or near the true max (e.g. 29/30 -> 25, 59/60 -> 55). The full case is handled by
-- the caller (shows "Full"). For tiny mags where max-5 would drop below the 5 floor, fall back to
-- max as the ceiling so the number stays sane.
local function ammo_approx(current, max)
    local a = math_floor((current + 2.5) / 5) * 5
    if a < 5 then a = 5 end
    local hi = max - 5
    if hi < 5 then hi = max end
    if a > hi then a = hi end
    return a
end

-- format ammo display based on display_mode
-- display_round: for ammo type name (chambered round)
-- tag_round: for ammo tag classification (magazine contents)
-- returns: message, ammo_type_key, tag_for_separate_line
local function format_ammo_message(text_msg, current, max, display_round, tag_round)
    local result

    if display_mode == 0 then
        -- text only
        result = get_translation(text_msg)
    elseif display_mode == 1 then
        -- numeric only
        result = string_format("%d/%d", current, max)
    elseif display_mode == 3 then
        -- Tarkov-like: "Full" when topped off, "Nearly empty" with only a few rounds, "About Half"
        -- around the midpoint, else a rough count (capped at max-5 so a near-full mag never reads max).
        -- Nearly-empty threshold is a few rounds, but bounded to a quarter of the mag so tiny mags
        -- (revolvers, tubes) don't read "Nearly empty" when they are actually fairly full.
        local near_thresh = math_min(5, math_floor(max * 0.25))
        if near_thresh < 1 then near_thresh = 1 end
        if current >= max then
            result = get_translation("st_ac_full")
        elseif current <= near_thresh then
            result = get_translation("st_ac_nearly_empty")
        elseif current > max * 0.4 and current <= max * 0.6 then
            result = get_translation("st_ac_about_half")
        else
            result = get_translation("st_ac_approx") .. " " .. tostring(ammo_approx(current, max))
        end
    else
        -- both
        result = string_format("%s (%d/%d)", get_translation(text_msg), current, max)
    end
    
    local ammo_type = nil
    local separate_tag = nil
    
    -- append ammo info if enabled and we have ammo
    if (show_ammo_type or show_ammo_tag) and (display_round or tag_round) then
        local ammo_str, atype, tag = format_ammo_type_string(display_round, tag_round)
        ammo_type = atype
        separate_tag = tag
        if ammo_str and ammo_str ~= "" then
            -- use comma only when ammo type name is shown
            local separator = show_ammo_type and ", " or " "
            result = result .. separator .. ammo_str
        end
    end
    
    return result, ammo_type, separate_tag
end

-- strip the wrapping parens from a tag: "(AP)" becomes "AP"
local function tag_content(tag)
    if not tag then return nil end
    return string_match(tag, "%((.+)%)") or tag
end

-- inline "name tag" chunk for the mismatch "+1" layout, honoring show_ammo_type /
-- show_ammo_tag. The tag's own parens are dropped because the caller wraps the whole
-- chunk in one set of parens. returns: chunk_string_or_nil, type_key
local function format_round_chunk(round_sec)
    local atype, tag, name = classify_round(round_sec)
    local tc = tag_content(tag)
    local show_name = show_ammo_type and name
    if show_name and show_ammo_tag and tc then
        name = remove_duplicate_suffix(name, tag)
        if name and name ~= "" then return name .. " " .. tc, atype end
        return tc, atype
    elseif show_name then
        return name, atype
    elseif show_ammo_tag and tc then
        return tc, atype
    end
    return nil, atype
end

-- the chambered round's short name + ammo tag, for the "+1 in chamber" expansion
local function format_chamber_string(chamber_round)
    if not chamber_round then return nil end
    local cn = gc(ui_item.get_sec_short_name(chamber_round))
    if not cn or cn == "" then return nil end
    -- local _, ctag = classify_ammo_by_name(cn)
    -- if ctag then return cn .. " " .. ctag end
    return cn
end

-- Build the mixed-load line "<level> (<mag>) + 1 (<chamber>)" plus optional colored segments.
-- The chamber is always one round on top of the magazine fill (retain_round), so this layout
-- applies at any fill level, not just Full. The mag chunk follows the ammo-type / ammo-tag
-- toggles; the chamber chunk shows name + tag normally, or only the tag in Tarkov-like mode.
-- base_clr colors the non-ammo parts (level text, parens, "+ 1"); each ammo name takes its own
-- type color. Returns: message_string, mag_type_key, segments_or_nil.
local function compose_mismatch(level, mag_sec, chamber_sec, base_clr)
    local mag_chunk, mtype = format_round_chunk(mag_sec)
    local chamber_chunk, ctype
    if display_mode == 3 then
        local catype, ctag = classify_round(chamber_sec)
        ctype = catype
        chamber_chunk = tag_content(ctag)
    else
        chamber_chunk, ctype = format_round_chunk(chamber_sec)
    end

    local parts = level
    if mag_chunk and mag_chunk ~= "" then parts = parts .. " (" .. mag_chunk .. ")" end
    parts = parts .. " + 1"
    if chamber_chunk and chamber_chunk ~= "" then parts = parts .. " (" .. chamber_chunk .. ")" end

    -- level word in the level color, each ammo name in its own ammo-type color, the static
    -- parens and "+ 1" white. Needs Colored Messages on and the custom overlay (the actor_menu
    -- line is single-color, so it keeps the flat path).
    local segments = nil
    if use_clr and custom_render then
        base_clr = base_clr or clr06_White
        local mag_clr = (color_ammo_type and mag_chunk and get_ammo_type_color(mtype)) or clr06_White
        local chamber_clr = (color_ammo_type and chamber_chunk and get_ammo_type_color(ctype)) or clr06_White
        segments = {}
        segments[#segments + 1] = { str = level, clr = base_clr }
        if mag_chunk and mag_chunk ~= "" then
            segments[#segments + 1] = { str = " (", clr = clr06_White }
            segments[#segments + 1] = { str = mag_chunk, clr = mag_clr }
            segments[#segments + 1] = { str = ")", clr = clr06_White }
        end
        segments[#segments + 1] = { str = " + 1", clr = clr06_White }
        if chamber_chunk and chamber_chunk ~= "" then
            segments[#segments + 1] = { str = " (", clr = clr06_White }
            segments[#segments + 1] = { str = chamber_chunk, clr = chamber_clr }
            segments[#segments + 1] = { str = ")", clr = clr06_White }
        end
    end

    return parts, mtype, segments
end

-- shared ammo status calculation
-- returns: message, color, ammo_type, separate_tag
local function get_ammo_status(weapon, weaponId, sec, in_grenade_mode, currentAmmo)
    local message = ""
    local clr = nil
    local ammo_type = nil
    local separate_tag = nil
    local segments = nil  -- per-chunk colored pieces for the mismatch "+1" line (custom render only)
    local msg_key = nil  -- st_ac_* id chosen by the active branch; used by minimalist bar override
    local display_round = nil  -- ammo section for type-name display (function-scoped so the minimalist override can reuse it)
    local tag_round = nil      -- ammo section for tag classification

    local mag_data = get_mag_loaded(weaponId)
    local is_supported = is_supported_weapon(sec)
    
    -- determine weapon status and message
    if is_jammed_weapon(weapon) then
        message = get_translation("st_ac_jammed")
        msg_key = "st_ac_jammed"
        clr = use_clr and clr00_Red or clr06_White

    elseif in_grenade_mode then
        message = currentAmmo == 1 and get_translation("st_ac_grenade") or get_translation("st_ac_empty")
        msg_key = currentAmmo == 1 and "st_ac_grenade" or "st_ac_empty"
        clr = use_clr and (currentAmmo == 1 and clr06_White or clr00_Red) or clr06_White

    elseif currentAmmo == 0 then
        if is_supported and not mag_data then
            message = get_translation("st_ac_noMag")
            msg_key = "st_ac_noMag"
        else
            message = get_translation("st_ac_empty")
            msg_key = "st_ac_empty"
        end
        clr = use_clr and clr00_Red or clr06_White
        
    else
        local max_ammo = 0
        local base_mag_size = SYS_GetParam(2, sec, "ammo_mag_size", 0)
        local is_chamber_only = false  -- Track if only chambered round remains
        local has_empty_mag = false    -- Track if magazine is inserted but empty
        local mag_has_chamber = false  -- retain_round: the loaded array carries a chamber round we must exclude from the fill level

        if not mag_data and is_supported then
            -- no magazine inserted, one in the chamber
            currentAmmo = 1
            max_ammo = 10
            is_chamber_only = true
            has_empty_mag = false
        elseif is_supported and mag_data then
            print_dbg("Checking magazine section: %s", mag_data.section)
            max_ammo = SYS_GetParam(2, mag_data.section, "max_mag_size") or 1

            -- the MagsRedux loaded array is the source of truth for round count (it drives
            -- display_round / chamber too). The engine get_ammo_in_magazine can desync from it
            -- (mag size mismatch), so trust the array length here, including the +1 chamber.
            if mag_data.loaded then
                currentAmmo = #mag_data.loaded
            end

            -- Per-weapon retain check: Mags only retains a chamber round on closed-bolt weapons
            -- (its own retain_round(weapon) is the config flag AND not open-bolt).
            -- A raw config read would wrongly subtract a chamber round on open-bolt weapons (full mag reading
            -- one short, wrong top-round name)
            -- So we fall back to the raw config on older Mags builds that lack the per-weapon function bruh
            local mag_retains_chamber
            if magazines and magazines.retain_round then
                mag_retains_chamber = magazines.retain_round(weapon)
            else
                mag_retains_chamber = magazines_mcm and magazines_mcm.get_config("retain_round")
            end
            if mag_retains_chamber then
                -- with retain_round: last in array is chambered, second-to-last is magazine top.
                -- the chamber is always present, so the fill level must use (loaded - 1).
                mag_has_chamber = true
                local mag_top = mag_data.loaded[#mag_data.loaded - 1]
                if mag_top then
                    display_round = mag_top
                    tag_round = mag_top
                else
                    -- only chambered round left, magazine is empty
                    is_chamber_only = true
                    has_empty_mag = true
                end
            else
                -- without retain_round: top of stack is what we'll fire next
                -- check if stack module exists (MagsRedux dependency)
                if stack and stack.peek then
                    display_round = stack.peek(mag_data.loaded)
                elseif mag_data.loaded and #mag_data.loaded > 0 then
                    -- fallback: get last element directly
                    display_round = mag_data.loaded[#mag_data.loaded]
                end
                tag_round = display_round
            end
        else
            -- non-MagsRedux weapon: get ammo section from weapon's ammo_class list
            display_round = get_sec_chambered(weapon)
            -- fallback to vanilla method if MagsRedux function returned nil
            if not display_round then
                display_round = get_vanilla_ammo_section(weapon)
            end
            tag_round = display_round
            max_ammo = base_mag_size
        end

        -- guard against division by zero
        if not max_ammo or max_ammo <= 0 then max_ammo = 1 end

        local curAmmoPerc = currentAmmo / max_ammo

        -- magazine fill excludes the retained chamber round, so a topped-off-onto-chamber state
        -- (loaded == max+1) is the only "Full"; firing it down to a full count of rounds with one
        -- in the chamber reads as one short (e.g. 29/30), not Full.
        local level_count = currentAmmo - (mag_has_chamber and 1 or 0)
        local level_perc = level_count / max_ammo

        -- resolve the chambered round vs the magazine top for the mismatch layout. retain_round
        -- keeps the chamber as the last entry of the loaded array; fall back to the engine-chambered
        -- section. The chamber only counts as a separate "+1" round when retain_round is on.
        local chamber_sec
        if mag_data and mag_data.loaded and #mag_data.loaded > 0 then
            chamber_sec = mag_data.loaded[#mag_data.loaded]
        end
        if not chamber_sec then
            chamber_sec = (get_sec_chambered and get_sec_chambered(weapon)) or get_vanilla_ammo_section(weapon)
        end
        local mag_sec = tag_round or display_round
        local chamber_differs = show_chamber_mismatch and mag_has_chamber
            and chamber_sec and mag_sec and chamber_sec ~= mag_sec

        if currentAmmo == max_ammo + 1 then
            msg_key = "st_ac_plus1"
            clr = clr06_White  -- plus1 is always white regardless of use_clr

            if chamber_differs then
                -- mixed load on a single line: "Full (mag) + 1 (chamber)".
                local level
                if display_mode == 1 then
                    level = string_format("%d/%d", currentAmmo, max_ammo)  -- numeric
                elseif display_mode == 2 then
                    level = get_translation("st_ac_full") .. string_format(" %d/%d", currentAmmo, max_ammo)  -- text + numeric
                else
                    level = get_translation("st_ac_full")
                end
                message, ammo_type, segments = compose_mismatch(level, mag_sec, chamber_sec, clr)
                separate_tag = nil
            else
                message, ammo_type, separate_tag = format_ammo_message("st_ac_plus1", currentAmmo, max_ammo, display_round, tag_round)
            end

        elseif curAmmoPerc > 1 then
            -- mag reports more than its size param (off-by-N capacity, extended mags, etc.).
            -- Show it as Full rather than the "Overfilled" state.
            message, ammo_type, separate_tag = format_ammo_message("st_ac_full", currentAmmo, max_ammo, display_round, tag_round)
            msg_key = "st_ac_full"
            clr = clr06_White

        elseif currentAmmo == 1 and base_mag_size == 2 then
            message, ammo_type, separate_tag = format_ammo_message("st_ac_just_one", currentAmmo, max_ammo, display_round, tag_round)
            msg_key = "st_ac_just_one"
            clr = use_clr and clr03_Amber or clr06_White

        elseif is_chamber_only then
            -- Chamber only - the "1 in the chamber" messages. This is where the optional chamber
            -- ammo type belongs (not on "Full + 1" / level messages).
            local prefix_key
            if has_empty_mag then
                message = get_translation("st_ac_empty_mag_oitc")
                msg_key = "st_ac_empty_mag_oitc"
                prefix_key = "st_ac_empty_mag_prefix"
            else
                message = get_translation("st_ac_no_mag_oitc")
                msg_key = "st_ac_no_mag_oitc"
                prefix_key = "st_ac_no_mag_prefix"
            end
            local combined = message  -- before the ammo suffix is appended below
            clr = use_clr and clr00_Red or clr06_White

            local cstr, cclr
            if show_chamber_ammo then
                local chamber_sec = (get_sec_chambered and get_sec_chambered(weapon)) or get_vanilla_ammo_section(weapon)
                cstr = format_chamber_string(chamber_sec)
                if cstr then
                    message = message .. string_format(" (%s)", cstr)
                    local ctype = classify_round(chamber_sec)
                    cclr = (use_clr and color_ammo_type and get_ammo_type_color(ctype)) or clr06_White
                end
            end

            -- colored split: status prefix ("Empty magazine"/"No magazine") in the level color,
            -- the static "in the chamber" remainder white, and the chambered round's name in its
            -- ammo-type color. The remainder is taken from the combined string itself (so the
            -- locale separator stays correct: " + " in EN, ", " in RU). Custom overlay only.
            if use_clr and custom_render then
                local prefix = get_translation(prefix_key)
                segments = {}
                if prefix and string_sub(combined, 1, #prefix) == prefix then
                    segments[#segments + 1] = { str = prefix, clr = clr00_Red }
                    local remainder = string_sub(combined, #prefix + 1)
                    if remainder ~= "" then
                        segments[#segments + 1] = { str = remainder, clr = clr06_White }
                    end
                else
                    segments[#segments + 1] = { str = combined, clr = clr00_Red }
                end
                if cstr then
                    segments[#segments + 1] = { str = " (", clr = clr06_White }
                    segments[#segments + 1] = { str = cstr, clr = cclr or clr06_White }
                    segments[#segments + 1] = { str = ")", clr = clr06_White }
                end
            end

        else
            -- calculate index based on percentage. level_count excludes the retained chamber, so
            -- a magazine that is full only reads "Full" together with the +1 (handled above).
            -- use ceil so 20% maps to index 2 (near_empty), not index 3 (less_half)
            local idx
            if level_count == max_ammo then
                idx = #messages -- Full
            else
                idx = clamp(math_ceil(level_perc * 10), 1, #messages - 1)
            end
            print_dbg("Ammo index: %s (%.1f%%, %d/%d)", idx, level_perc * 100, level_count, max_ammo)

            local msg_id = messages[idx].m
            local lvl_clr = use_clr and messages[idx].c or clr06_White
            msg_key = msg_id
            clr = lvl_clr

            if chamber_differs then
                -- mixed load at a partial fill: "<level> (mag) + 1 (chamber)". Build the level text
                -- with no ammo append (nil rounds), then attach the mag + chamber chunks.
                local level_text = format_ammo_message(msg_id, level_count, max_ammo, nil, nil)
                message, ammo_type, segments = compose_mismatch(level_text, mag_sec, chamber_sec, lvl_clr)
                separate_tag = nil
            else
                message, ammo_type, separate_tag = format_ammo_message(msg_id, level_count, max_ammo, display_round, tag_round)
            end
            print_dbg("Color: use_clr=%s, idx=%s, clr=%s", tostring(use_clr), idx, tostring(clr))
        end

        -- apply ammo type color based on highlight mode (Whole Message).
        -- Only when Colored Messages is enabled. Applies in minimalist bar mode too:
        -- the whole bar takes the ammo-type color (use "Combined" to keep the level color
        -- and color only the type/tag).
        if use_clr and color_ammo_type and ammo_type and highlight_ammo_mode == 1 then
            local ammo_clr = get_ammo_type_color(ammo_type)
            print_dbg("Highlight override: mode=%s, ammo_type=%s, ammo_clr=%s", highlight_ammo_mode, ammo_type, tostring(ammo_clr))
            if ammo_clr then
                clr = ammo_clr
            end
        end
    end

    -- minimalist bar override: replace descriptive/numeric text with the block bar.
    -- Runs last so it covers every branch (jammed, grenade, chamber-only, level, etc.).
    -- Keeps the ammo-level color already chosen above for the bar itself.
    if minimalist_bar and msg_key then
        local bar = MIN_BAR[msg_key]
        if bar then
            message = bar
            ammo_type = nil
            separate_tag = nil
            segments = nil  -- bar replaces the composed mismatch line; drop its colored segments

            -- optionally show ammo type/tag next to the bar (when those MCM options are on
            -- and we actually have a round to classify; chamber-only/jammed/empty have none).
            -- format_ammo_type_string already honors show_ammo_type / show_ammo_tag /
            -- highlight_ammo_mode, so mode 2 still splits the tag onto the second line.
            if (show_ammo_type or show_ammo_tag) and (display_round or tag_round) then
                local ammo_str, atype, sep_tag = format_ammo_type_string(display_round, tag_round)
                ammo_type = atype
                separate_tag = sep_tag
                if highlight_ammo_mode == 2 then
                    -- Separate Lines + bar: keep the bar ALONE on line 1 and put the whole
                    -- ammo chunk (name + tag) together on line 2. format_ammo_type_string
                    -- splits the name (ammo_str) from the tag (sep_tag) for the normal text
                    -- path, so recombine them here instead of hanging the name off the bar.
                    if ammo_str and ammo_str ~= "" and sep_tag and sep_tag ~= "" then
                        separate_tag = ammo_str .. " " .. sep_tag
                    elseif ammo_str and ammo_str ~= "" then
                        separate_tag = ammo_str
                    end
                    -- message stays as the bar; separate_tag (above) feeds line 2
                elseif ammo_str and ammo_str ~= "" then
                    message = bar .. " " .. ammo_str
                end
            end
        end
    end

    return message, clr, ammo_type, separate_tag, segments
end

-- display ammo status with optional second line
local function display_ammo_status(message, clr, ammo_type, separate_tag, segments)
    if not show_message then return end
    -- hide_msg_on_inspect: suppress message only when path A is letting the native inspect anim play.
    -- All other paths (fake reload, lower, hide/show, auto-check after reload) keep the flag false,
    -- so they still show the message.
    if hide_msg_on_inspect and ac_pending_inspect_anim_playing then return end

    -- mismatch "+1" line with per-chunk colors: render as side-by-side single-color segments
    -- (only built when custom render + Colored Messages + a non-None highlight mode).
    if segments and custom_render then
        get_ac_overlay():show_segments(segments, msg_duration)
        ac_message_until = time_global() + math_floor(msg_duration * 1000)
        return
    end

    local tag_clr = (use_clr and color_ammo_type and get_ammo_type_color(ammo_type)) or clr06_White
    local base_clr = clr or clr06_White

    if custom_render then
        -- Combined (3): single line, two-tone (level-color text + ammo-color tag), drawn as
        -- two side-by-side single-color controls (show_combined). One %c string is NOT used
        -- because center/right alignment counts a mid-string %c tag's literal chars as render
        -- width and opens a large gap
        if highlight_ammo_mode == 3 and separate_tag and separate_tag ~= "" then
            get_ac_overlay():show_combined(message, base_clr, separate_tag, tag_clr, msg_duration)
        else
            -- Separate (2): ammo tag on a colored 2nd line. None/Whole: no 2nd line
            local line2 = (highlight_ammo_mode == 2) and separate_tag or nil
            get_ac_overlay():show(message, base_clr, line2, tag_clr, msg_duration)
        end
    else
        -- actor_menu's message line has no complex mode (base set_msg = SetTextST + one
        -- SetTextColor), so it can't color part of a line. Both Combined (3) and Separate (2)
        -- therefore put the colored ammo tag on a 2nd line (matches the MCM "on a second line
        -- otherwise" note); merging it inline would force the whole line to the level color
        -- (e.g. all-white for "Full + 1"). None/Whole already merged the tag into message
        display_message(message, clr)
        local line2 = (highlight_ammo_mode == 2 or highlight_ammo_mode == 3) and separate_tag or nil
        if line2 and line2 ~= "" then
            actor_menu.set_msg(2, line2, msg_duration, tag_clr)
        end
    end

    -- Track when the message visually disappears. If the next ammo-check key press lands
    -- after the cooldown has expired but before this time, the stale message is hidden.
    -- Note: ac_cooldown_until and ac_last_weapon_id are set in check_Ammo at commit time
    -- (using the weapon the check was about, not the actor's currently active weapon),
    -- so they are not overwritten here
    ac_message_until = time_global() + math_floor(msg_duration * 1000)
end

-- Public single-line display used by sibling features (e.g. One-Key Fire Mode). Routes through the
-- custom HUD overlay when "Custom Text Rendering" is on, otherwise the actor_menu message line, so
-- those features inherit the same font, position and duration. clr is an ARGB int or nil (white).
function show_single_line(text, clr, pos)
    if not text or text == "" then return end
    local base_clr = clr or clr06_White
    if custom_render then
        get_ac_overlay():show(text, base_clr, nil, nil, msg_duration, pos)
        ac_message_until = time_global() + math_floor(msg_duration * 1000)
    else
        -- not display_message: that path is gated by the ammo-check "Show Message" toggle, which
        -- is unrelated to a caller like the fire mode feature that owns its own enable switch
        actor_menu.set_msg(1, text, msg_duration, base_clr)
    end
end

-- whether the custom HUD overlay is active. Callers that build per-character colored strings
-- (inline %c tags) need this: the overlay renders complex mode, the actor_menu line does not.
function is_custom_render()
    return custom_render and true or false
end

-- shared on-screen message duration (seconds), so sibling features match the ammo-check timing
function get_msg_duration()
    return msg_duration or 2
end

-- configured render-position index (see ac_render_layout); sibling features resolving "default"
function get_render_position()
    return render_position or 3
end

-- Public multi-segment display for callers that need several colors on one line (e.g. fire mode
-- dots: white lit dots, almost-black empty dots, optional colored letter). Each segment is a
-- single-color control, so it works at any render position. Falls back to a single concatenated,
-- single-color line when the custom overlay is off (per-segment color is then unavailable).
function show_segments(segments, pos)
    if not (segments and #segments > 0) then return end
    if custom_render then
        get_ac_overlay():show_segments(segments, msg_duration, pos)
        ac_message_until = time_global() + math_floor(msg_duration * 1000)
    else
        local buf = {}
        for i = 1, #segments do buf[#buf + 1] = segments[i].str or "" end
        actor_menu.set_msg(1, table.concat(buf), msg_duration, segments[1].clr)
    end
end

-- auto-check after reload
local pending_reload_check = false

-- Post-reload delay before the auto-check message, shrunk to match a fast reload. The Fast Reload
-- feature speeds the reload anim, so the fixed AUTO_CHECK_DELAY would feel sluggish after it; divide
-- by the active fast-reload multiplier (1 when none) so the message keeps pace. Shotgun open/close is
-- not a fast-reload path, so the getter returns 1 there and the delay is unchanged.
local function auto_check_delay()
    local fr = ammo_check_fastreload_mcm
    if fr and fr.consume_fast_reload_speedup then
        local mult = fr.consume_fast_reload_speedup()
        if mult and mult > 1 then return AUTO_CHECK_DELAY / mult end
    end
    return AUTO_CHECK_DELAY
end

-- callback for auto-check after reload
local function auto_check_after_reload_callback()
    local actor = db.actor
    if not actor then return true end
    
    local weapon = actor:active_item()
    if not weapon or not IsWeapon(weapon) then return true end
    
    -- Build and display message directly (no weapon hide animation)
    check_Ammo_silent()
    return true
end

-- callback for HUD animation end
function actor_on_hud_animation_end(item, section, motion, state, slot)
    -- release the reload-block window (and restore the Mags handler) as soon as the check animation
    -- ends, instead of waiting for the AC_ANIM_BLOCK_MS cap. Runs before the auto_check_reload
    -- early-return below so it always fires.
    if ac_anim_block_until > 0 or ac_mags_suppressed then
        ac_end_reload_block()
    end

    -- Path A inspect finished: clear the flag here, not only at the next check_Ammo. Left set,
    -- it would keep hide_msg_on_inspect suppressing unrelated later messages (e.g. every auto-check after reload).
    -- Only one weapon HUD anim plays at a time, so any weapon anim ending while the flag is set means the inspect is over.
    if ac_pending_inspect_anim_playing and item and IsWeapon(item) then
        ac_pending_inspect_anim_playing = false
    end

    -- stop empty mag sound if playing (handles cancelled animations)
    if empty_mag_sound and empty_mag_sound:playing() then
        empty_mag_sound:stop()
        empty_mag_sound = nil
    end
    
    if not auto_check_reload then return end
    if not motion then return end
    if not item then return end
    if not IsWeapon(item) then return end
    
    -- skip if this was a fake reload (we already displayed the message)
    if is_fake_reload then
        print_dbg("Skipping auto-check: was fake reload")
        is_fake_reload = false
        return
    end
    
    -- Anchor patterns to ^anm_ to avoid matching unrelated motion names
    -- (e.g., anm_chamber_open, anm_grenade_close, anm_preload).
    -- check reload first (most common case)
    if string_find(motion, "^anm_[Rr]eload") then
        pending_reload_check = false
        print_dbg("Reload animation ended: %s", motion)
        CreateTimeEvent("ammo_check", "auto_check", auto_check_delay(), auto_check_after_reload_callback)
        return
    end

    -- shotgun open: start tracking
    if string_find(motion, "^anm_[Oo]pen") then
        pending_reload_check = true
        print_dbg("Shotgun reload started: %s", motion)
        return
    end

    -- shotgun close: only if we're tracking a reload
    if pending_reload_check and string_find(motion, "^anm_[Cc]lose") then
        pending_reload_check = false
        print_dbg("Shotgun reload ended: %s", motion)
        CreateTimeEvent("ammo_check", "auto_check", auto_check_delay(), auto_check_after_reload_callback)
    end
end

function actor_on_weapon_jammed(weapon)
    print_dbg("Weapon jammed")
end

-- ### ANIMATION MUTATOR FOR FAKE RELOAD

-- check if weapon has a specific HUD animation
local function has_animation(section, anm)
    local hud_section = SYS_GetParam(0, section, "hud") or section
    return SYS_GetParam(0, hud_section, anm)
end

-- animation mutator for fake reload - intercepts inspect animation
local function mag_check_animation(anm_table, obj)
    -- handle end of ammo check animation
    if wpn_checking and obj and wpn_checking:id() == obj:id() and do_ammo_check_anim == 2 then
        wpn_checking = nil
        do_ammo_check_anim = nil
        
        if det_active then
            db.actor:show_detector(true)
        end
        det_active = nil
    end
    
    -- handle start of ammo check animation (state 4 = inspect/bore)
    -- ONLY fires for path A (engine-driven inspect anim). For fake-reload paths the mod
    -- has already chosen the anim explicitly via play_hud_motion - rewriting anm_name
    -- here would hijack that choice (the original bug: anm_reload -> anm_ammo_check).
    -- No-magazine fallback suppression: GAMMA's engine auto-plays the mag-check bore
    -- (anm_ammo_check / _empty / _no_mag) when the weapon bores, independent of our mutator. When the
    -- no-mag fallback is active we do NOT want that inspect, so rewrite it to a plain idle here.
    if obj and obj:get_state() == 4 and time_global() < ac_suppress_inspect_until then
        local nm = anm_table and anm_table.anm_name and tostring(anm_table.anm_name)
        if nm and string.find(nm, "^anm_ammo_check") then
            -- Replace the engine's auto mag-check bore with the idle animation, so no inspect plays.
            -- anm_idle loops and would leave the weapon stuck in state 4 (eBore) - the fallback branch
            -- schedules a forced switch_state(0) to pull it back to idle so further checks aren't
            -- blocked. The weapon just stays put (no inspect, no shake of the mag-check).
            anm_table.anm_name = "anm_idle"
            print_dbg("No-mag fallback: suppressed engine inspect %s -> anm_idle", nm)
        end
        return
    end

    if ac_inspect_pending and obj and obj:get_state() == 4 then
        wpn_checking = obj
        local sec = obj:section()

        local is_supported = is_supported_weapon(obj)
        local has_mag_data = get_mag_loaded(obj:id())
        local ammo_in_mag = obj:get_ammo_in_magazine()

        -- "1 in chamber, magazine itself empty" -> treat as empty for variant selection.
        -- Heuristic: ammo == 1 and the weapon's mag holds more than 1 (so single-shot
        -- weapons don't get mislabelled when fully loaded with their single round).
        -- The MCM option `treat_one_chamber_as_non_empty` opts OUT of this (default off).
        local treat_as_empty = false
        if (not treat_one_chamber_as_non_empty) and ammo_in_mag == 1 then
            local mag_size = SYS_GetParam(2, sec, "ammo_mag_size", 0)
            if mag_size and mag_size > 1 then
                treat_as_empty = true
            end
        end

        -- try different ammo check animations
        -- if none exist, DON'T change the animation - let the default anm_bore play
        -- Decide which variant we'd want first; only write to anm_table if it'd actually change.
        -- Writing back the same value can still cause the engine to retrigger camera effects
        -- on some weapons (notably L96A1), so the no-op guard matters.
        local target_anim = nil
        if animation_common and animation_common.has_animation then
            if is_supported and not has_mag_data and animation_common.has_animation(sec, "anm_ammo_check_no_mag") then
                target_anim = "anm_ammo_check_no_mag"
            elseif (ammo_in_mag == 0 or treat_as_empty) and animation_common.has_animation(sec, "anm_ammo_check_empty") then
                target_anim = "anm_ammo_check_empty"
            elseif animation_common.has_animation(sec, "anm_ammo_check") then
                target_anim = "anm_ammo_check"
            end
        end

        if target_anim then
            if anm_table.anm_name ~= target_anim then
                print_dbg("Ammo check animation mutated: %s -> %s (treat_as_empty=%s, ammo=%s)", tostring(anm_table.anm_name), target_anim, tostring(treat_as_empty), tostring(ammo_in_mag))
                anm_table.anm_name = target_anim
            else
                print_dbg("Ammo check: engine already on %s, no mutation needed", target_anim)
            end
        else
            -- no ammo_check animation - let the default inspect animation play
            print_dbg("No ammo_check animation for %s, using default inspect: %s", sec, tostring(anm_table.anm_name))
        end

        do_ammo_check_anim = 2     -- enable the end-branch cleanup below
        ac_inspect_pending = false -- one-shot
    end
end

-- game initialization
function on_game_start()
    -- setup MagsRedux integration (needs BOTH modules: some setups provide one without the other)
    if magazine_binder and magazines then
        get_data = magazine_binder.get_data
        set_data = magazine_binder.set_data
        get_mag_loaded = magazine_binder.get_mag_loaded or get_mag_loaded_shim
        is_supported_weapon = magazine_binder.is_supported_weapon
        is_jammed_weapon = magazines.is_jammed_weapon
        get_sec_chambered = magazines.get_sec_chambered
        print_dbg("MagsRedux installed. Working in integrated mode.")
    else
        get_data = null_function
        set_data = null_function
        is_supported_weapon = null_function
        get_mag_loaded = null_function
        is_jammed_weapon = null_function
        get_sec_chambered = nil_function  -- must return nil, not false
        print_dbg("MagsRedux not found. Working in standalone mode.")
    end

    RegisterScriptCallback("actor_on_first_update", actor_on_first_update)
    RegisterScriptCallback("on_option_change", on_option_change)
    RegisterScriptCallback("on_key_press", on_key_press)
    RegisterScriptCallback("on_key_press", on_key_press_debug)  -- always-on debug keys (mode-independent)
    RegisterScriptCallback("on_before_key_press", on_before_key_press)
    RegisterScriptCallback("actor_on_hud_animation_end", actor_on_hud_animation_end)
    RegisterScriptCallback("actor_on_weapon_jammed", actor_on_weapon_jammed)

    -- register animation mutator for fake reload mode
    if animation_common and animation_common.add_anim_mutator then
        animation_common.add_anim_mutator(mag_check_animation, 2)
        print_dbg("Animation mutator registered: mag_check_animation (priority 2)")
    end

    install_lower_weapon_sprint_compat()
end

-- ### Lower Weapon Sprint compatibility
--
-- The "Lower Weapon Sprint" mod lowers the weapon the instant the player starts sprinting. It decides
-- between "lower now" and "wait for the current animation, then lower" purely from weapon:get_state():
-- state 0 (idle) or 3 (aim) means lower immediately, any other (busy) state means keep polling until
-- the weapon returns to idle. A real reload or the engine's own anm_ammo_check sits in a busy state, so
-- it is left alone. Our fake reload plays through play_hud_motion, which keeps the weapon logically idle
-- (state 0), so that mod cuts it the moment sprint begins.
--
-- Fix without touching that mod's files: it is loaded as the global table lower_weapon_sprint, and its
-- idle-poll function wait_for_animation_end(wpn) is the one that does the lowering. Wrap that function so
-- that while our fake reload is in flight it keeps re-polling (mirroring the mod's own busy-state branch)
-- instead of lowering. Once our animation ends (is_fake_reload clears) it hands straight back to the
-- original, which then lowers normally if the player is still sprinting. No-op when the mod is absent.
function install_lower_weapon_sprint_compat()
    if not (lower_weapon_sprint and lower_weapon_sprint.wait_for_animation_end) then return end

    local lws_orig_wait = lower_weapon_sprint.wait_for_animation_end
    lower_weapon_sprint.wait_for_animation_end = function(wpn)
        if is_fake_reload and wpn then
            ResetTimeEvent("wait_for_animation_end", wpn:id(), 0.05)  -- keep waiting, do not lower yet
            return false
        end
        return lws_orig_wait(wpn)
    end

    print_dbg("Lower Weapon Sprint detected: wait_for_animation_end wrapped for fake-reload compat")
end

-- ### ANIMATION DEBUG SYSTEM
-- when debug mode is ON:
--   numpad 0-9 = test weapon state 0-9
--   numpad * = list all animations for current weapon
--   numpad + = increase bolt/pump animation delay (+0.1s)
--   numpad - = decrease bolt/pump animation delay (-0.1s)
--   numpad / = play anm_bore animation
--   numpad . = play anm_idle animation

-- debug: test different weapon states
function debug_test_state(state_num)
    local weapon = db.actor and db.actor:active_item()
    if not weapon or not IsWeapon(weapon) then
        db.actor:give_game_news("AmmoCheck Debug", "No weapon active!", "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    local sec = weapon:section()
    local current_state = weapon:get_state()
    
    -- Only switch if weapon is idle
    if current_state ~= 0 then
        db.actor:give_game_news("AmmoCheck Debug", "Weapon not idle! State: " .. current_state, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    db.actor:give_game_news("AmmoCheck Debug", "Testing state " .. state_num .. " on " .. sec, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
    weapon:switch_state(state_num)
end

-- debug: list all animations for current weapon
function debug_list_animations()
    local weapon = db.actor and db.actor:active_item()
    if not weapon or not IsWeapon(weapon) then
        db.actor:give_game_news("AmmoCheck Debug", "No weapon active!", "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    local sec = weapon:section()
    local hud_section = ini_sys:r_string_ex(sec, "hud") or sec
    
    local animations_to_check = {
        "anm_idle", "anm_reload", "anm_reload_empty",
        "anm_open", "anm_close", "anm_add_cartridge",
        "anm_bore", "anm_shots", "anm_shoot",
        "anm_ammo_check", "anm_ammo_check_empty", "anm_ammo_check_no_mag",
    }
    
    local found = {}
    for _, anm in ipairs(animations_to_check) do
        local value = SYS_GetParam(0, hud_section, anm)
        if value then
            table.insert(found, anm)
        end
    end
    
    local msg = sec .. ":\n" .. table.concat(found, ", ")
    db.actor:give_game_news("AmmoCheck Debug - Animations", msg, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 8000, 0)
    
    -- also print to console for full details
    printf("[AmmoCheck DEBUG] Weapon: %s | HUD: %s", sec, hud_section)
    for _, anm in ipairs(found) do
        printf("  [+] %s", anm)
    end
end

-- debug: adjust animation delay for bolt/pump weapons
function debug_adjust_delay(delta)
    local weapon = db.actor and db.actor:active_item()
    if not weapon or not IsWeapon(weapon) then
        db.actor:give_game_news("AmmoCheck Debug", "No weapon active!", "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    local sec = weapon:section()
    
    if not ammo_check_weapons then
        db.actor:give_game_news("AmmoCheck Debug", "Weapons config not loaded!", "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    if not ammo_check_weapons.adjust_delay then
        db.actor:give_game_news("AmmoCheck Debug", "adjust_delay not available!", "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    local new_delay, weapon_type = ammo_check_weapons.adjust_delay(sec, delta)
    
    if new_delay then
        local type_name = weapon_type == "bolt" and "Bolt-action" or "Pump-action"
        local msg = string.format("%s delay: %.1fs", type_name, new_delay)
        db.actor:give_game_news("AmmoCheck Debug", msg, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 2000, 0)
        printf("[AmmoCheck DEBUG] %s %s delay set to %.1fs", sec, weapon_type, new_delay)
    else
        db.actor:give_game_news("AmmoCheck Debug", "Weapon not in bolt/pump lists: " .. sec, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
    end
end

function debug_play_animation(anim_name)
    local weapon = db.actor and db.actor:active_item()
    if not weapon or not IsWeapon(weapon) then
        db.actor:give_game_news("AmmoCheck Debug", "No weapon active!", "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    local sec = weapon:section()
    
    -- Check if weapon has this animation
    local hud_sec = ini_sys:r_string_ex(sec, "hud")
    if not hud_sec then
        db.actor:give_game_news("AmmoCheck Debug", "No HUD section for: " .. sec, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    local anim_exists = ini_sys:r_string_ex(hud_sec, anim_name)
    if not anim_exists then
        local msg = string.format("%s: no '%s' animation", sec, anim_name)
        db.actor:give_game_news("AmmoCheck Debug", msg, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        return
    end
    
    -- play the animation with error protection
    local success, err = pcall(function()
        weapon:play_hud_motion(anim_name, true, 0, 1, 0)
    end)
    
    if not success then
        local msg = string.format("Failed to play '%s' on %s", anim_name, sec)
        db.actor:give_game_news("AmmoCheck Debug", msg, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 3000, 0)
        printf("[AmmoCheck DEBUG] %s: %s", msg, tostring(err))
        return
    end
    
    local msg = string.format("Playing '%s' on %s", anim_name, sec)
    db.actor:give_game_news("AmmoCheck Debug", msg, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 2000, 0)
    printf("[AmmoCheck DEBUG] %s", msg)
end


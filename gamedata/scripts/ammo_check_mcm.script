-- Decide whether an ammo check on this weapon would fall back to the no-magazine fallback in path A:
-- weapon has a proper inspect anim (so the ENGINE inspect, triggered by the ammo-check key, would
-- play), it is mags-supported, has NO magazine, and has no dedicated anm_ammo_check_no_mag. In that
-- case on_before_key_press consumes the key so the engine inspect never starts - check_Ammo can mutate
-- that inspect but cannot cancel it, which is why the fallback alone left the inspect animation playing.
function ac_should_block_inspect_no_mag(weapon, sec)
    if not enable_animations then return false end
    if not weapon or not IsWeapon(weapon) then return false end
    if weapon:weapon_in_grenade_mode() then return false end

    local has_proper_inspect = has_animation(sec, "anm_ammo_check") or
                               has_animation(sec, "anm_ammo_check_empty") or
                               has_animation(sec, "anm_ammo_check_no_mag")
    if not has_proper_inspect then return false end

    -- bolt-action routes that skip path A (mirror check_Ammo)
    local _bolt_cfg = get_bolt_action_config(sec)
    if _bolt_cfg and (_bolt_cfg.external_mag or (_bolt_cfg.override_inspect and fake_reload_bolt_cycle)) then
        return false
    end

    -- a dedicated no-mag inspect should play, not the fallback
    if has_animation(sec, "anm_ammo_check_no_mag") then return false end

    if not magazines then return false end
    -- read the mag state BEFORE is_supported_weapon (it lazily creates a full default mag for unbound
    -- weapons - that side effect would mask a genuinely mag-less weapon)
    local mag_loaded = magazine_binder and get_mag_loaded(weapon:id())
    if not is_supported_weapon(weapon) then return false end
    if mag_loaded then return false end
    return true
end

-- main ammo check function
function check_Ammo(skip_animation)
    local actor = db.actor
    if not actor then return end

    local weapon = actor:active_item()

    -- validation checks with early returns
    if not weapon then return end
    if not IsWeapon(weapon) then return end
    if IsItem("fake_ammo_wpn", nil, weapon) then return end

    -- Cooldown handling:
    --   - Same weapon, still in cooldown -> ignore key.
    --   - Different weapon, still in cooldown -> hide stale message, reset, proceed.
    --   - Cooldown expired but the previous message is still visually on screen (because
    --     msg_duration is longer than the cooldown window) -> hide it first, then proceed.
    -- The "defer until weapon idle" recursion clears the cooldown before re-calling
    -- check_Ammo so it isn't blocked by its own first arming.
    local now = time_global()
    if ac_cooldown_until > 0 and now < ac_cooldown_until then
        if weapon:id() == ac_last_weapon_id then
            print_dbg("Ammo check key ignored - previous check still in cooldown (same weapon).")
            return
        end
        print_dbg("Ammo check: weapon changed (was id=%s, now id=%s) - clearing stale message.", tostring(ac_last_weapon_id), tostring(weapon:id()))
        actor_menu.set_msg(1, "", 0)
        actor_menu.set_msg(2, "", 0)
        if ac_overlay then ac_overlay:hide() end
    elseif ac_message_until > 0 and now < ac_message_until then
        -- Cooldown over, but the previous message is still visible. Hide it first.
        print_dbg("Ammo check: cooldown expired but stale message still on screen - hiding it.")
        actor_menu.set_msg(1, "", 0)
        actor_menu.set_msg(2, "", 0)
        if ac_overlay then ac_overlay:hide() end
    end

    local weaponId = weapon:id()
    local sec = weapon:section()
    local currentState = weapon:get_state()
    local in_grenade_mode = weapon:weapon_in_grenade_mode()
    print_dbg("check_Ammo ENTER section=%s state=%s grenade_mode=%s", sec, tostring(currentState), tostring(in_grenade_mode))

    -- if weapon is busy (animation playing), just show message without animation
    local weapon_busy = (currentState ~= 0)

    -- if in grenade mode and check is disabled, return
    if in_grenade_mode and not check_grenade_mode then return end

    local currentAmmo = weapon:get_ammo_in_magazine()
    if not currentAmmo then return end

    -- Arm cooldown for this check, AFTER the validation returns above so a no-op press
    -- (e.g. grenade mode with its check disabled) cannot silently lock out the next 3s.
    -- Fixed window regardless of msg_duration so the player can re-trigger quickly; the
    -- message may visually outlive the cooldown
    ac_cooldown_until = now + AC_COOLDOWN_MS
    ac_last_weapon_id = weaponId
    ac_message_until = 0  -- reset; will be set by display_ammo_status when the new message displays

    -- get ammo status using shared function
    local message, clr, ammo_type, separate_tag, segments = get_ammo_status(weapon, weaponId, sec, in_grenade_mode, currentAmmo)

    disable_info("sleep_active")

    -- store in globals for TimeEvent access
    ac_pending_message = message
    ac_pending_clr = clr
    ac_pending_ammo_type = ammo_type
    ac_pending_separate_tag = separate_tag
    ac_pending_segments = segments

    -- cleanup previous events
    RemoveTimeEvent("ammo_check", "message_delay")
    RemoveTimeEvent("ammo_check", "restore_weapon")
    RemoveTimeEvent("ammo_check", "restore_det")
    RemoveTimeEvent("ammo_check", "defer_to_idle")
    RemoveTimeEvent("AmmoCheck_BoltCycle", "close"..weaponId)
    
    -- clear any lingering animation state
    do_ammo_check_anim = nil
    wpn_checking = nil
    is_fake_reload = false       -- in case the previous fake reload's anim-end callback never fired
    pending_reload_check = false -- in case a previous shotgun open never got its matching close
    ac_pending_inspect_anim_playing = false  -- only set true in path A success branch below
    ac_inspect_pending = false   -- one-shot mutator-arm; cleared in case path A's state-4 callback never fired
    
    -- ### ANIMATION LOGIC
    
    -- check if weapon has PROPER custom mag inspect animation
    local has_proper_inspect = has_animation(sec, "anm_ammo_check") or
                               has_animation(sec, "anm_ammo_check_empty") or
                               has_animation(sec, "anm_ammo_check_no_mag")

    -- bolt-action override: skip path A (native inspect anim) in two cases:
    --   1. weapon flagged { override_inspect = true } for internal-mag entries, and the
    --      fake_reload_bolt_cycle toggle is on -> we want bolt cycle instead of inspect.
    --   2. weapon flagged { external_mag = true } - we always route external-mag bolt-actions
    --      through fake reload (or forced bolt cycle), never the engine's inspect anim.
    if has_proper_inspect then
        local _bolt_cfg = get_bolt_action_config(sec)
        if _bolt_cfg then
            if _bolt_cfg.external_mag then
                print_dbg("Ammo check for %s - external_mag bolt-action, skipping inspect anim.", sec)
                has_proper_inspect = false
            elseif _bolt_cfg.override_inspect and fake_reload_bolt_cycle then
                print_dbg("Ammo check for %s - bolt-action override_inspect, ignoring inspect anim.", sec)
                has_proper_inspect = false
            end
        end
    end

    -- if skip requested: just show message
    if skip_animation then
        CreateTimeEvent("ammo_check", "message_delay", 0, delayed_display_callback)
        return
    end

    -- if weapon is busy (drawing, reloading, firing, etc.): defer the check until
    -- the weapon returns to idle so the animation can play properly. Without this
    -- the previous behavior was to just print the message and skip the animation,
    -- which the user found unintuitive when pressing the ammo check key during weapon
    -- drawing. Bounded by a 5s timeout so a stuck state can't block forever.
    if weapon_busy then
        print_dbg("Ammo check for %s - weapon busy (state=%s), deferring until idle.", sec, tostring(currentState))
        local _start_time = time_global()
        CreateTimeEvent("ammo_check", "defer_to_idle", 0.1, function()
            local _actor = db.actor
            if not _actor then return true end
            local _w = _actor:active_item()
            if not _w or not IsWeapon(_w) then return true end

            if time_global() - _start_time > 5000 then
                print_dbg("Ammo check deferred: 5s timeout, abandoning.")
                ac_cooldown_until = 0  -- release the guard so the user can press again
                ac_last_weapon_id = 0
                return true
            end

            if _w:get_state() ~= 0 then
                return false  -- still busy, keep polling
            end

            print_dbg("Ammo check: weapon now idle, running deferred check.")
            -- Clear the guard cooldown set by the first call so the recursion isn't blocked.
            ac_cooldown_until = 0
            ac_last_weapon_id = 0
            check_Ammo()
            return true
        end)
        return
    end

    -- Arm the reload-block window. From here check_Ammo plays (or is about to play) an animation;
    -- while it runs the weapon is non-idle, and on_before_key_press blocks the reload bind until
    -- the weapon returns to idle. Message-only paths below keep the weapon idle, so they never
    -- actually block reload even though the window is armed.
    if block_reload_during_check then
        ac_anim_block_until = time_global() + AC_ANIM_BLOCK_MS
        -- Also suppress the Mags Redux reload handler (ret_value alone won't stop it). Deferred one
        -- tick: the anim-playing flags / non-idle state are set by the branches BELOW, so check them
        -- next tick and only suppress when an animation actually started (a message-only check keeps
        -- the weapon idle and must not have Mags reload blocked). Skipped when One-Key is enabled,
        -- which already owns/suppresses the Reload bind (re-registering Mags would undo that).
        if not onekey_enabled then
            RemoveTimeEvent("ac_mags_block", "arm")
            RemoveTimeEvent("ac_mags_block", "restore")
            CreateTimeEvent("ac_mags_block", "arm", 0, function()
                local w = db.actor and db.actor:active_item()
                if ac_pending_inspect_anim_playing or is_fake_reload
                   or (w and IsWeapon(w) and w:get_state() ~= 0) then
                    set_ac_mags_suppressed(true)
                    -- safety restore if actor_on_hud_animation_end never fires (stuck/cancelled anim)
                    CreateTimeEvent("ac_mags_block", "restore", AC_ANIM_BLOCK_MS / 1000 + 0.1, function()
                        set_ac_mags_suppressed(false)
                        return true
                    end)
                end
                return true
            end)
        end
    end

    -- if animations are disabled: just show message with delay
    if not enable_animations then
        print_dbg("Ammo check for %s - animations disabled, showing message only.", sec)
        CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
        return
    end

    -- Grenade-launcher mode: use a dedicated animation (default: lower weapon) instead of the
    -- normal inspect / fake-reload path, which plays the confusing grenade-LOAD animation.
    if in_grenade_mode then
        print_dbg("Ammo check for %s - grenade mode, grenade_anim_mode=%s.", sec, grenade_anim_mode)
        if grenade_anim_mode == 1 then
            -- hide/show weapon
            ac_pending_slot = actor:active_slot()
            actor:activate_slot(0)
            weapon_hidden = true
            CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
        elseif grenade_anim_mode == 2 then
            -- fake reload (old behavior: plays the grenade-load animation)
            do_ammo_check_anim = 1
            is_fake_reload = true
            det_active = actor:active_detector() or nil
            if det_active then det_active:switch_state(2) end
            play_reload_animation(weapon)
            schedule_fake_reload_message(FAKE_RELOAD_MSG_DELAY)
            CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
        elseif grenade_anim_mode == 3 then
            -- message only
            CreateTimeEvent("ammo_check", "message_delay", 0, delayed_display_callback)
        else
            -- 0: lower weapon (default)
            game.actor_lower_weapon(true)
            CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
        end
        return
    end

    -- [ Top-priority per-weapon override ]--
    -- Bypasses all other animation logic when ammo_check_override has an entry for this weapon.
    -- Force-mode (force_*) values are picked when MCM "Force Bolt Cycle for External-Mag Rifles"
    -- is ON and the entry has at least one force_* field; otherwise default fields apply.
    local override = get_ammo_check_override(sec)
    if override then
        local use_force_mode = force_bolt_cycle_external_mag and (
            override.force_anim ~= nil or override.force_fake_reload or override.force_fallback
        )

        local m_fallback, m_fake_reload, m_anim, m_sound
        if use_force_mode then
            m_fallback     = override.force_fallback
            m_fake_reload  = override.force_fake_reload
            m_anim         = override.force_anim
            m_sound        = override.force_sound
        else
            m_fallback     = override.fallback
            m_fake_reload  = override.fake_reload
            m_anim         = override.anim
            m_sound        = override.sound
        end

        local mode_label = use_force_mode and " (force)" or ""

        if m_fallback then
            print_dbg("Ammo check for %s - override = fallback%s, using fake_reload_fallback=%s.", sec, mode_label, fake_reload_fallback)
            if fake_reload_fallback == 0 then
                ac_pending_slot = actor:active_slot()
                actor:activate_slot(0)
                weapon_hidden = true
                CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
            else
                game.actor_lower_weapon(true)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
            end
            return
        elseif m_fake_reload then
            print_dbg("Ammo check for %s - override = fake_reload%s, using standard fake-reload path.", sec, mode_label)
            do_ammo_check_anim = 1
            is_fake_reload = true
            det_active = actor:active_detector() or nil
            if det_active then
                det_active:switch_state(2)
            end
            play_reload_animation(weapon)
            schedule_fake_reload_message(FAKE_RELOAD_MSG_DELAY)
            CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
            return
        elseif m_anim and has_animation(sec, m_anim) then
            print_dbg("Ammo check for %s - override = anim %s%s.", sec, m_anim, mode_label)
            do_ammo_check_anim = 1
            is_fake_reload = true
            det_active = actor:active_detector() or nil
            if det_active then
                det_active:switch_state(2)
            end
            play_hud_animation(weapon, m_anim, m_sound)
            CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
            CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
            return
        end
        -- override entry exists but the active mode has no usable fields -> fall through
        print_dbg("Ammo check for %s - override entry has no usable %s fields, falling through to normal logic.", sec, use_force_mode and "force-mode" or "default-mode")
    end

    -- [ A) weapon HAS proper mag inspect animation ]--
    if has_proper_inspect then
        -- check if we need to apply no_magazine_fallback. Pass the weapon OBJECT (not the section)
        -- to is_supported_weapon: with only a section it skips the real base-type check and can
        -- wrongly report unsupported, which would suppress the no-mag handling entirely.
        local uses_magazines = magazines and is_supported_weapon(weapon)
        local needs_no_mag_fallback = false

        -- No-mag detection matches the animation mutator: mags-supported AND no magazine loaded.
        -- Use get_mag_loaded directly, NOT weapon_default_magazine - that lookup returns nil for some
        -- detachable weapons (so the fallback was skipped and the default mag-check anim played).
        -- Internal-mag / tube weapons keep mag_data (Mags creates it from their default_mag), so they
        -- stay non-nil here and are not mistaken for mag-less.
        if uses_magazines and not get_mag_loaded(weaponId) then
            needs_no_mag_fallback = true
        end

        -- No magazine, but the weapon ships a dedicated no-mag inspect (anm_ammo_check_no_mag):
        -- play that animation instead of the fallback. Fall through to the native inspect path; the
        -- mutator picks the _no_mag variant. The fallback only applies when no such animation exists,
        -- so the regular mag-check animation never plays when there is no magazine to check.
        if needs_no_mag_fallback and has_animation(sec, "anm_ammo_check_no_mag") then
            print_dbg("Ammo check for %s - no mag but has anm_ammo_check_no_mag, playing it (ignoring no_magazine_fallback).", sec)
            needs_no_mag_fallback = false
        end

        if needs_no_mag_fallback then
            -- weapon has proper inspect but NO magazine - cancel animation and apply fallback
            print_dbg("Ammo check for %s - has proper inspect but no mag, cancelling and using no_magazine_fallback=%s.", sec, no_magazine_fallback)

            -- arm the mutator to neutralize the engine's auto mag-check bore (it plays anm_ammo_check
            -- on its own when the weapon bores; the fallback alone cannot stop it)
            ac_suppress_inspect_until = time_global() + 1500

            -- The mutator swaps the bore to anm_idle, which loops and would leave the weapon stuck in
            -- state 4 (eBore). Poll briefly and force it back to idle so later checks aren't blocked.
            RemoveTimeEvent("ammo_check", "ac_unstick_bore")
            local _unstick_start = time_global()
            CreateTimeEvent("ammo_check", "ac_unstick_bore", 0, function()
                local w = db.actor and db.actor:active_item()
                if not (w and IsWeapon(w)) then return true end
                if w:get_state() == 4 then
                    w:switch_state(0)  -- pull out of the (suppressed, looping) bore
                    return true
                end
                return time_global() - _unstick_start > 1500  -- stop polling after the window
            end)

            -- cancel any started animation and camera effects
            if level.stop_hud_motion then
                level.stop_hud_motion()
            end
            weapon:switch_state(0)  -- switch to idle
            
            -- remove weapon camera effectors (they use random IDs 5000-10000)
            if level.check_cam_effector and level.remove_cam_effector then
                for id = 5000, 10000 do
                    if level.check_cam_effector(id) then
                        level.remove_cam_effector(id)
                    end
                end
            end
            
            -- apply no_magazine_fallback
            if no_magazine_fallback == 0 then
                -- hide/show weapon
                ac_pending_slot = actor:active_slot()
                actor:activate_slot(0)
                weapon_hidden = true
                CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
            elseif no_magazine_fallback == 1 then
                -- lower weapon
                game.actor_lower_weapon(true)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
            else
                -- none - just show message
                CreateTimeEvent("ammo_check", "message_delay", 0, delayed_display_callback)
            end
            return
        end
        
        -- has proper inspect and magazine is loaded (or internal mag) - let native animation play
        print_dbg("Ammo check for %s - has proper inspect animation, NOT interfering.", sec)
        ac_pending_inspect_anim_playing = true  -- gates hide_msg_on_inspect
        -- Arm the mutator (path-A-only flag) so it can override the engine's anm_bore choice
        -- with anm_ammo_check / _empty / _no_mag when state 4 fires. Using a dedicated flag
        -- (not do_ammo_check_anim) ensures fake-reload paths don't trigger this mutation.
        ac_inspect_pending = true
        CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
        return
    end
    
    -- [ B) weapon DOES NOT have proper mag inspect ]--
    
    -- B.1) default mode: hide/show weapon
    if anim_mode == 0 then
        print_dbg("Ammo check for %s - using hide/show weapon.", sec)
        ac_pending_slot = actor:active_slot()
        actor:activate_slot(0)
        weapon_hidden = true
        CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
        return
    end
    
    -- B.2) lower weapon mode
    if anim_mode == 1 then
        print_dbg("Ammo check for %s - using lower weapon.", sec)
        game.actor_lower_weapon(true)
        CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
        return
    end
    
    -- B.3) fake reload mode
    if anim_mode == 2 then
        -- check if weapon should be ignored for fake reload animations
        if fake_reload_ignore_list and should_ignore_fake_animations(sec) then
            print_dbg("Ammo check for %s - in ignore list, using fake_reload_fallback=%s.", sec, fake_reload_fallback)
            
            if fake_reload_fallback == 0 then
                -- hide/show weapon
                ac_pending_slot = actor:active_slot()
                actor:activate_slot(0)
                weapon_hidden = true
                CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
            else
                -- lower weapon
                game.actor_lower_weapon(true)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
            end
            return
        end
        
        -- check if weapon uses detachable magazines (MagsRedux supported). Pass the weapon object,
        -- not the section: a section-only query skips the base-type check and can misreport support.
        local uses_magazines = magazines and is_supported_weapon(weapon)
        
        if uses_magazines then
            -- check if this is a DETACHABLE magazine weapon vs INTERNAL magazine (tube, etc.)
            -- weapon_default_magazine returns nil for internal magazine weapons
            local has_detachable_mag = magazine_binder and magazine_binder.weapon_default_magazine and 
                                       magazine_binder.weapon_default_magazine(weapon)
            
            if has_detachable_mag then
                -- "Force Bolt Cycle for External-Mag Rifles" early route:
                -- the default detachable-mag handling below uses fake reload (anm_reload),
                -- which doesn't honor the force toggle. If the weapon is flagged in
                -- bolt_action_rifles with external_mag = true AND the toggle is on, play
                -- the explicit bolt cycle here instead.
                if force_bolt_cycle_external_mag then
                    local _bolt_cfg = get_bolt_action_config(sec)
                    if _bolt_cfg and _bolt_cfg.external_mag then
                        local use_custom_anim = _bolt_cfg.anim and has_animation(sec, _bolt_cfg.anim)
                        local use_open_close = has_animation(sec, "anm_open") and has_animation(sec, "anm_close")
                        local delay = _bolt_cfg.delay or 0.7

                        if use_custom_anim or use_open_close then
                            print_dbg("Ammo check for %s - external_mag + force_bolt_cycle, playing explicit bolt cycle.", sec)
                            do_ammo_check_anim = 1
                            is_fake_reload = true
                            det_active = actor:active_detector() or nil
                            if det_active then
                                det_active:switch_state(2)
                            end

                            if use_custom_anim then
                                play_hud_animation(weapon, _bolt_cfg.anim, _bolt_cfg.sound)
                                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                                CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                            else
                                play_open_close_animation(weapon, delay)
                                schedule_fake_reload_message(delay + BOLT_PUMP_MSG_OFFSET)
                            end
                            return
                        else
                            print_dbg("Ammo check for %s - external_mag + force_bolt_cycle but no usable cycle anim, falling through to fake reload.", sec)
                        end
                    end
                end

                -- DETACHABLE magazine weapon - check if magazine is actually loaded
                local current_magazine = get_mag_loaded(weaponId)

                if current_magazine then
                    -- before using fake reload, check if weapon has custom animation override
                    local custom_config = get_pistol_smg_config(sec) or get_rifle_config(sec) or get_sniper_config(sec)
                    
                    if custom_config then
                        if custom_config.anim and has_animation(sec, custom_config.anim) then
                            print_dbg("Ammo check for %s - using custom %s animation (override).", sec, custom_config.anim)
                            
                            do_ammo_check_anim = 1
                            is_fake_reload = true
                            
                            det_active = actor:active_detector() or nil
                            if det_active then
                                det_active:switch_state(2)
                            end
                            
                            play_hud_animation(weapon, custom_config.anim, custom_config.sound)
                            CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                            CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                            return
                        elseif custom_config.delay and has_animation(sec, "anm_open") and has_animation(sec, "anm_close") then
                            print_dbg("Ammo check for %s - using open/close with %.2fs delay (override).", sec, custom_config.delay)
                            
                            do_ammo_check_anim = 1
                            is_fake_reload = true
                            
                            det_active = actor:active_detector() or nil
                            if det_active then
                                det_active:switch_state(2)
                            end
                            
                            play_open_close_animation(weapon, custom_config.delay)
                            schedule_fake_reload_message(custom_config.delay + BOLT_PUMP_MSG_OFFSET)
                            return
                        end
                    end
                    
                    -- has magazine, no custom override - play fake reload animation
                    print_dbg("Ammo check for %s - detachable mag weapon with mag, using fake reload animation.", sec)
                    
                    do_ammo_check_anim = 1  -- mark that we're doing our own animation
                    is_fake_reload = true   -- prevent auto-check duplicate
                    
                    det_active = actor:active_detector() or nil
                    if det_active then
                        det_active:switch_state(2)
                    end
                    
                    play_reload_animation(weapon)
                    schedule_fake_reload_message(FAKE_RELOAD_MSG_DELAY)
                    return
                else
                    -- no magazine loaded - apply no_magazine_fallback
                    print_dbg("Ammo check for %s - detachable mag weapon, no mag, using no_magazine_fallback=%s.", sec, no_magazine_fallback)
                    
                    if no_magazine_fallback == 0 then
                        -- hide/show weapon
                        ac_pending_slot = actor:active_slot()
                        actor:activate_slot(0)
                        weapon_hidden = true
                        CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
                    elseif no_magazine_fallback == 1 then
                        -- lower weapon
                        game.actor_lower_weapon(true)
                        CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                    else
                        -- none - just show message, no animation
                        CreateTimeEvent("ammo_check", "message_delay", 0, delayed_display_callback)
                    end
                    return
                end
            end
            -- else: internal magazine weapon - fall through to exclusion lists below
            print_dbg("Ammo check for %s - internal magazine weapon (MagsRedux), checking exclusion lists.", sec)
        end
        
        -- [ weapon does NOT use detachable magazines ]--
        
        -- check 1: break-action shotgun (TOZ-34 style)
        local break_config = get_break_action_config(sec)
        if break_config and has_animation(sec, break_config.anim) then
            print_dbg("Ammo check for %s - break-action, using %s animation.", sec, break_config.anim)
            
            do_ammo_check_anim = 1  -- mark that we're doing our own animation
            is_fake_reload = true   -- prevent auto-check duplicate
            
            det_active = actor:active_detector() or nil
            if det_active then
                det_active:switch_state(2)
            end
            
            if play_hud_animation(weapon, break_config.anim, break_config.sound) then
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                return
            else
                -- animation failed, restore state and fall through to fallback
                print_dbg("Animation failed for %s, falling back", sec)
                do_ammo_check_anim = nil
                is_fake_reload = false
                if det_active then
                    db.actor:show_detector(true)
                    det_active = nil
                end
                -- continue to fallback
            end
        end
        
        -- check 2: bolt-action rifle
        -- Decision matrix:
        --   internal-mag entry (no external_mag flag):
        --     fake_reload_bolt_cycle ON  -> play explicit bolt cycle
        --     fake_reload_bolt_cycle OFF -> use fake_reload_fallback (truly suppress cycling)
        --   external-mag entry (external_mag = true):
        --     force_bolt_cycle_external_mag ON  -> play explicit bolt cycle (override)
        --     force_bolt_cycle_external_mag OFF -> fall through to fake reload (anm_reload)
        --     (the regular fake_reload_bolt_cycle toggle does NOT apply here)
        local bolt_config = get_bolt_action_config(sec)
        local is_external_mag_bolt = bolt_config and bolt_config.external_mag
        local play_bolt_cycle = bolt_config and (
            (is_external_mag_bolt and force_bolt_cycle_external_mag) or
            ((not is_external_mag_bolt) and fake_reload_bolt_cycle)
        )
        print_dbg("check_Ammo trace for %s: bolt_config=%s, is_external_mag=%s, force=%s, toggle=%s, play_bolt_cycle=%s",
            sec, tostring(bolt_config ~= nil), tostring(is_external_mag_bolt),
            tostring(force_bolt_cycle_external_mag), tostring(fake_reload_bolt_cycle), tostring(play_bolt_cycle))

        if bolt_config and not play_bolt_cycle and not is_external_mag_bolt then
            -- internal-mag bolt-action with toggle off -> fake_reload_fallback
            print_dbg("Ammo check for %s - bolt-action toggle OFF, using fake_reload_fallback=%s.", sec, fake_reload_fallback)
            if fake_reload_fallback == 0 then
                ac_pending_slot = actor:active_slot()
                actor:activate_slot(0)
                weapon_hidden = true
                CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
            else
                game.actor_lower_weapon(true)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
            end
            return
        end

        if bolt_config and play_bolt_cycle then
            local use_custom_anim = bolt_config.anim and has_animation(sec, bolt_config.anim)
            local use_open_close = has_animation(sec, "anm_open") and has_animation(sec, "anm_close")
            local delay = bolt_config.delay or 0.7  -- default delay if not specified

            -- priority 1: use custom animation if specified and exists
            if use_custom_anim then
                print_dbg("Ammo check for %s - bolt-action, using custom %s animation.", sec, bolt_config.anim)

                do_ammo_check_anim = 1  -- mark that we're doing our own animation
                is_fake_reload = true   -- prevent auto-check duplicate

                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end

                -- eject one round if option enabled and there's ammo
                if fake_reload_bolt_eject and currentAmmo > 0 then
                    local ammo_section = get_vanilla_ammo_section(weapon)
                    if ammo_section then
                        weapon:set_ammo_elapsed(currentAmmo - 1)
                        alife_create_item(ammo_section, actor, { ammo = 1 })
                        print_dbg("Ejected round: %s (remaining: %d)", ammo_section, currentAmmo - 1)
                        ac_pending_message, ac_pending_clr, ac_pending_ammo_type, ac_pending_separate_tag, ac_pending_segments =
                            get_ammo_status(weapon, weaponId, sec, in_grenade_mode, currentAmmo - 1)
                    end
                end

                play_hud_animation(weapon, bolt_config.anim, bolt_config.sound)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                return

            -- priority 2: use anm_open/anm_close (either as configured or as fallback)
            elseif use_open_close then
                print_dbg("Ammo check for %s - bolt-action, using open/close with %.2fs delay.", sec, delay)

                do_ammo_check_anim = 1  -- mark that we're doing our own animation
                is_fake_reload = true   -- prevent auto-check duplicate

                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end

                -- eject one round if option enabled and there's ammo
                if fake_reload_bolt_eject and currentAmmo > 0 then
                    local ammo_section = get_vanilla_ammo_section(weapon)
                    if ammo_section then
                        weapon:set_ammo_elapsed(currentAmmo - 1)
                        alife_create_item(ammo_section, actor, { ammo = 1 })
                        print_dbg("Ejected round: %s (remaining: %d)", ammo_section, currentAmmo - 1)
                        ac_pending_message, ac_pending_clr, ac_pending_ammo_type, ac_pending_separate_tag, ac_pending_segments =
                            get_ammo_status(weapon, weaponId, sec, in_grenade_mode, currentAmmo - 1)
                    end
                end

                play_open_close_animation(weapon, delay)
                schedule_fake_reload_message(delay + BOLT_PUMP_MSG_OFFSET)
                return
            end
        end
        
        -- check 3: pump-action shotgun
        -- Toggle OFF + normal entry: route to fake_reload_fallback (truly stops pump-racking).
        -- Toggle OFF + no_cycle flag: still fall through to fake reload (anm_reload IS the pump
        --   rack visual for these guns anyway, and they're marked specifically to use it).
        -- Toggle ON + no_cycle flag: skip explicit cycle, fall through to fake reload.
        -- Toggle ON + normal entry: play anm_open/close or custom anim as before.
        local pump_config = get_pump_action_config(sec)
        if pump_config and not fake_reload_pump_rack and not pump_config.no_cycle then
            print_dbg("Ammo check for %s - pump-action toggle OFF, using fake_reload_fallback=%s.", sec, fake_reload_fallback)
            if fake_reload_fallback == 0 then
                ac_pending_slot = actor:active_slot()
                actor:activate_slot(0)
                weapon_hidden = true
                CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
            else
                game.actor_lower_weapon(true)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
            end
            return
        end

        if pump_config and not pump_config.no_cycle then
            local use_custom_anim = pump_config.anim and has_animation(sec, pump_config.anim)
            local use_open_close = has_animation(sec, "anm_open") and has_animation(sec, "anm_close")
            local delay = pump_config.delay or 0.5  -- default delay if not specified

            -- priority 1: use custom animation if specified and exists
            if use_custom_anim then
                print_dbg("Ammo check for %s - pump-action, using custom %s animation.", sec, pump_config.anim)

                do_ammo_check_anim = 1  -- mark that we're doing our own animation
                is_fake_reload = true   -- prevent auto-check duplicate

                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end

                -- eject one shell if option enabled, there's ammo, and weapon not excluded
                if fake_reload_pump_eject and currentAmmo > 0 and not should_exclude_shell_eject(sec) then
                    local ammo_section = get_vanilla_ammo_section(weapon)
                    if ammo_section then
                        weapon:set_ammo_elapsed(currentAmmo - 1)
                        alife_create_item(ammo_section, actor, { ammo = 1 })
                        print_dbg("Ejected shell: %s (remaining: %d)", ammo_section, currentAmmo - 1)
                        ac_pending_message, ac_pending_clr, ac_pending_ammo_type, ac_pending_separate_tag, ac_pending_segments =
                            get_ammo_status(weapon, weaponId, sec, in_grenade_mode, currentAmmo - 1)
                    end
                end

                play_hud_animation(weapon, pump_config.anim, pump_config.sound)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                return

            -- priority 2: use anm_open/anm_close (either as configured or as fallback)
            elseif use_open_close then
                print_dbg("Ammo check for %s - pump-action, using open/close with %.2fs delay.", sec, delay)

                do_ammo_check_anim = 1  -- mark that we're doing our own animation
                is_fake_reload = true   -- prevent auto-check duplicate

                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end

                -- eject one shell if option enabled, there's ammo, and weapon not excluded
                if fake_reload_pump_eject and currentAmmo > 0 and not should_exclude_shell_eject(sec) then
                    local ammo_section = get_vanilla_ammo_section(weapon)
                    if ammo_section then
                        weapon:set_ammo_elapsed(currentAmmo - 1)
                        alife_create_item(ammo_section, actor, { ammo = 1 })
                        print_dbg("Ejected shell: %s (remaining: %d)", ammo_section, currentAmmo - 1)
                        ac_pending_message, ac_pending_clr, ac_pending_ammo_type, ac_pending_separate_tag, ac_pending_segments =
                            get_ammo_status(weapon, weaponId, sec, in_grenade_mode, currentAmmo - 1)
                    end
                end

                play_open_close_animation(weapon, delay)
                schedule_fake_reload_message(delay + BOLT_PUMP_MSG_OFFSET)
                return
            end
        end
        
        -- check 4: pistol/SMG with custom animation
        local pistol_config = get_pistol_smg_config(sec)
        if pistol_config then
            local use_custom_anim = pistol_config.anim and has_animation(sec, pistol_config.anim)
            local use_open_close = has_animation(sec, "anm_open") and has_animation(sec, "anm_close")
            local delay = pistol_config.delay or 0.4  -- default delay if not specified
            
            if use_custom_anim then
                print_dbg("Ammo check for %s - pistol/smg, using custom %s animation.", sec, pistol_config.anim)
                
                do_ammo_check_anim = 1
                is_fake_reload = true
                
                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end
                
                play_hud_animation(weapon, pistol_config.anim, pistol_config.sound)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                return
            elseif use_open_close then
                print_dbg("Ammo check for %s - pistol/smg, using open/close with %.2fs delay.", sec, delay)
                
                do_ammo_check_anim = 1
                is_fake_reload = true
                
                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end
                
                play_open_close_animation(weapon, delay)
                schedule_fake_reload_message(delay + BOLT_PUMP_MSG_OFFSET)
                return
            end
        end
        
        -- check 5: rifle with custom animation
        local rifle_config = get_rifle_config(sec)
        if rifle_config then
            local use_custom_anim = rifle_config.anim and has_animation(sec, rifle_config.anim)
            local use_open_close = has_animation(sec, "anm_open") and has_animation(sec, "anm_close")
            local delay = rifle_config.delay or 0.5  -- default delay if not specified
            
            if use_custom_anim then
                print_dbg("Ammo check for %s - rifle, using custom %s animation.", sec, rifle_config.anim)
                
                do_ammo_check_anim = 1
                is_fake_reload = true
                
                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end
                
                play_hud_animation(weapon, rifle_config.anim, rifle_config.sound)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                return
            elseif use_open_close then
                print_dbg("Ammo check for %s - rifle, using open/close with %.2fs delay.", sec, delay)
                
                do_ammo_check_anim = 1
                is_fake_reload = true
                
                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end
                
                play_open_close_animation(weapon, delay)
                schedule_fake_reload_message(delay + BOLT_PUMP_MSG_OFFSET)
                return
            end
        end
        
        -- check 6: sniper rifle with custom animation
        local sniper_config = get_sniper_config(sec)
        if sniper_config then
            local use_custom_anim = sniper_config.anim and has_animation(sec, sniper_config.anim)
            local use_open_close = has_animation(sec, "anm_open") and has_animation(sec, "anm_close")
            local delay = sniper_config.delay or 0.6  -- default delay if not specified
            
            if use_custom_anim then
                print_dbg("Ammo check for %s - sniper, using custom %s animation.", sec, sniper_config.anim)
                
                do_ammo_check_anim = 1
                is_fake_reload = true
                
                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end
                
                play_hud_animation(weapon, sniper_config.anim, sniper_config.sound)
                CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
                CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                return
            elseif use_open_close then
                print_dbg("Ammo check for %s - sniper, using open/close with %.2fs delay.", sec, delay)
                
                do_ammo_check_anim = 1
                is_fake_reload = true
                
                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end
                
                play_open_close_animation(weapon, delay)
                schedule_fake_reload_message(delay + BOLT_PUMP_MSG_OFFSET)
                return
            end
        end
        
        -- [ fallback: weapons not in custom lists ]--
        if empty_mag_fallback == 0 then
            -- try reload animation (using play_hud_motion which doesn't trigger reload logic)
            print_dbg("Ammo check for %s - using reload animation fallback.", sec)
            
            do_ammo_check_anim = 1
            is_fake_reload = true
            
            det_active = actor:active_detector() or nil
            if det_active then
                det_active:switch_state(2)
            end
            
            local current_ammo = weapon:get_ammo_in_magazine()
            if has_animation(sec, "anm_reload") then
                -- temporarily set ammo to 1 so animation_common doesn't switch to anm_reload_empty
                if current_ammo == 0 then
                    weapon:set_ammo_elapsed(1)
                end
                -- use state=7 to set pending flag (prevents movement interruption)
                local success, err = pcall(function()
                    weapon:play_hud_motion("anm_reload", true, 7, 1, 0)
                end)
                if current_ammo == 0 then
                    weapon:set_ammo_elapsed(0)  -- restore immediately
                end
                
                if success then
                    -- play sound manually - store it so we can stop on cancel
                    local sound_file = ini_sys:r_string_ex(sec, "snd_reload")
                    if sound_file and sound_file ~= "$no_sound" then
                        -- stop any previous sound
                        if empty_mag_sound and empty_mag_sound:playing() then
                            empty_mag_sound:stop()
                        end
                        empty_mag_sound = sound_object(sound_file)
                        if empty_mag_sound then
                            empty_mag_sound:play(db.actor, 0, sound_object.s2d)
                        end
                    end
                end
            elseif has_animation(sec, "anm_bore") then
                play_hud_animation(weapon, "anm_bore", "snd_bore")
            else
                game.actor_lower_weapon(true)
            end
            
            schedule_fake_reload_message(FAKE_RELOAD_MSG_DELAY)
            CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
            return
            
        elseif empty_mag_fallback == 1 then
            -- try safe animations (anm_bore/anm_idle)
            local fallback_anim = nil
            local fallback_sound = nil
            
            if has_animation(sec, "anm_bore") then
                fallback_anim = "anm_bore"
                fallback_sound = "snd_bore"
            elseif has_animation(sec, "anm_idle") then
                fallback_anim = "anm_idle"
                fallback_sound = nil
            end
            
            if fallback_anim then
                print_dbg("Ammo check for %s - using %s fallback (no MagsRedux/not in lists).", sec, fallback_anim)
                
                do_ammo_check_anim = 1
                is_fake_reload = true
                
                det_active = actor:active_detector() or nil
                if det_active then
                    det_active:switch_state(2)
                end
                
                play_hud_animation(weapon, fallback_anim, fallback_sound)
                
                schedule_fake_reload_message(FAKE_RELOAD_MSG_DELAY)
                CreateTimeEvent("ammo_check", "restore_det", 0.1, restore_detector_after_anim, weapon)
                return
            end
            -- fall through to fake_reload_fallback if no safe animation found
        end
        
        -- [ fallback: use fake_reload_fallback ]--
        if fake_reload_fallback == 0 then
            -- hide/show weapon
            print_dbg("Ammo check for %s - fallback to hide/show weapon.", sec)
            ac_pending_slot = actor:active_slot()
            actor:activate_slot(0)
            weapon_hidden = true
            CreateTimeEvent("ammo_check", "restore_weapon", 0, restore_weapon_callback)
        else
            -- lower weapon
            print_dbg("Ammo check for %s - fallback to lower weapon.", sec)
            game.actor_lower_weapon(true)
            CreateTimeEvent("ammo_check", "message_delay", busy_hands_delay, delayed_display_callback)
        end
        return
    end
end

-- news system with deduplication
local old_news = {}

function give_news(message)
    if old_news[message] then return end
    old_news[message] = true

    print_dbg(message)
    if db.actor then
        db.actor:give_game_news("AmmoCheck", message, "ui_inGame2_D_Ohotnik_na_mutantov", 0, 5000, 0)
    end
end

local ac_pending_inspect_anim_playing = false  -- state flag: true when path A lets the native inspect anim run; gates hide_msg_on_inspect. MUST be declared above display_ammo_status so its upvalue capture sees this local (Lua resolves names at function-definition time).
local ac_inspect_pending = false  -- arms the mutator to override engine's anm_bore -> anm_ammo_check[_empty|_no_mag] in path A only. Distinct from do_ammo_check_anim so fake-reload paths (which use play_hud_motion) don't have their explicit anim_name rewritten by the mutator.
local ac_suppress_inspect_until = 0  -- time_global() (ms) window during which the mutator neutralizes the engine's AUTO mag-check bore (anm_ammo_check[_empty]) to a plain idle. Set when the no-magazine fallback runs: GAMMA's engine plays the mag-check bore on its own, so the fallback (lower/hide) must also suppress that inspect or it plays on top.
local ac_cooldown_until = 0  -- time_global() value (ms) when the ammo-check-key cooldown expires. Fixed AC_COOLDOWN_MS window from when check_Ammo commits. Subsequent key presses for the SAME weapon while still in cooldown are ignored.
local ac_last_weapon_id = 0  -- weapon id the previous check was for. If the player switches weapons, the next key press resets cooldown + hides stale text and proceeds with the new weapon.
local ac_message_until = 0   -- time_global() value (ms) when the displayed message visually disappears. Tracked separately from cooldown because msg_duration (1-5s) may outlive the cooldown (3s) - we hide the stale message before processing the next press.
local ac_anim_block_until = 0  -- time_global() (ms) upper bound for the reload-block window. While set and the weapon is non-idle (the check animation is playing), on_before_key_press blocks the reload bind so it cannot cut the animation short.

-- Fixed cooldown window for the ammo-check key, independent of msg_duration (which only
